---
// Landing-page card. One card per package; links to the package overview
// page (`/<pkg>/`) where the user can pick a version. Counts reflect the
// latest available version.
import { loadBundleNav } from "../lib/nav.ts";
import { getBackends } from "../lib/backends.ts";

interface Props {
  pkg: string;
  latest: string;
  versionCount: number;
}

const { pkg, latest, versionCount } = Astro.props;

const { blobStore } = await getBackends();
const nav = await loadBundleNav(blobStore, pkg, latest);

const docCount = nav.docs.length + nav.tutorials.length;
const exampleCount = nav.examples.length;
const summary = typeof nav.meta.summary === "string" ? nav.meta.summary : null;
const href = `/${pkg}/`;
---

<a class="bundle-card" href={href} data-pkg={pkg} data-summary={summary ?? ""}>
  <div class="bundle-card-header">
    {
      nav.logoDataUrl ? (
        <img class="bundle-card-logo" src={nav.logoDataUrl} alt={`${pkg} logo`} />
      ) : (
        <span class="bundle-card-logo-empty" aria-hidden="true">
          {pkg.slice(0, 2).toUpperCase()}
        </span>
      )
    }
    <div class="bundle-card-title">
      <span class="bundle-card-pkg">{pkg}</span>
      <span class="bundle-card-version">
        {latest}
        {versionCount > 1 ? ` · ${versionCount} versions` : ""}
      </span>
    </div>
  </div>

  {summary ? <p class="bundle-card-summary">{summary}</p> : null}

  <div class="bundle-card-counts">
    <div class="bundle-card-count">
      <span class="bundle-card-count-num">{nav.qualnames.length}</span>
      <span class="bundle-card-count-label">API</span>
    </div>
    {
      docCount > 0 ? (
        <div class="bundle-card-count">
          <span class="bundle-card-count-num">{docCount}</span>
          <span class="bundle-card-count-label">Docs</span>
        </div>
      ) : null
    }
    {
      exampleCount > 0 ? (
        <div class="bundle-card-count">
          <span class="bundle-card-count-num">{exampleCount}</span>
          <span class="bundle-card-count-label">Examples</span>
        </div>
      ) : null
    }
  </div>
</a>
