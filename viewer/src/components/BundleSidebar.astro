---
// Sidebar for bundle pages. Identity block at the top, then Docs / Tutorials
// / Examples / API sections. Docs/Tutorials/Examples are driven by the
// view-model in `nav.ts`; API is the per-bundle search island + the compact
// qualname list.
import BundleSearch from "./BundleSearch.tsx";
import { qualnameToSlug } from "../lib/ir-reader.ts";
import type { BundleNav, NavEntry, TocItem } from "../lib/nav.ts";

interface Props {
  nav: BundleNav;
  activeQualname?: string;
  activeDocPath?: string;
  activeExamplePath?: string;
}

const { nav, activeQualname, activeDocPath, activeExamplePath } = Astro.props;
const bundleHref = `/${nav.pkg}/${nav.version}/`;
const summary = typeof nav.meta.summary === "string" ? nav.meta.summary : null;

// Build a tree-style flat list for the API section. Always shows depth-1
// modules; when a module at depth n is active, expands its ancestors and
// shows the active module's children (depth n+1). Items with `:` are class
// members, not modules — they're excluded here and only reachable via search.
interface ApiTreeItem {
  qualname: string;
  label: string;
  depth: number;
  isActive: boolean;
  isAncestor: boolean;
}

function buildApiTreeItems(qualnames: string[], active: string | undefined): ApiTreeItem[] {
  const modules = qualnames.filter((qa) => !qa.includes(":"));

  // Ancestors of the active module — the set of qualnames that prefix it.
  const activePath = new Set<string>();
  if (active) {
    const parts = active.split(".");
    for (let i = 1; i <= parts.length; i++) {
      activePath.add(parts.slice(0, i).join("."));
    }
  }

  const items: ApiTreeItem[] = [];
  for (const qa of modules) {
    const parts = qa.split(".");
    const depth = parts.length;
    // Depth-1 entries are always shown. Deeper entries are shown only when
    // their direct parent is on the active path (ancestor or active itself).
    const show = depth === 1 || activePath.has(parts.slice(0, -1).join("."));
    if (!show) continue;
    items.push({
      qualname: qa,
      label: parts[parts.length - 1],
      depth,
      isActive: qa === active,
      isAncestor: activePath.has(qa) && qa !== active,
    });
  }
  return items;
}

const apiTreeItems = buildApiTreeItems(nav.qualnames, activeQualname);

// The toc comes from meta/toc.cbor. When it's empty we still show the flat
// `docs` list below so the section isn't an awkward empty stub.
const hasToc = nav.toc.length > 0;

function labelForEntry(e: NavEntry): string {
  return e.name;
}

function isDocActive(path: string): boolean {
  return activeDocPath === path;
}

function isExampleActive(path: string): boolean {
  return activeExamplePath === path;
}

function isTocActive(item: TocItem): boolean {
  // Match the active doc path against the toc ref's href. Cheap check that
  // avoids re-parsing URLs.
  if (!item.href || !activeDocPath) return false;
  const encoded = activeDocPath.split(":").map(encodeURIComponent).join("/");
  return item.href.endsWith(`/docs/${encoded}/`);
}

function isTocSectionExpanded(item: TocItem): boolean {
  // Expand children only when we're inside this section (the item itself or
  // one of its direct children is the active page).
  return isTocActive(item) || item.children.some((child) => isTocActive(child));
}
---

<aside class="bundle-sidebar" aria-label="Bundle navigation">
  <a class="bundle-identity" href={bundleHref}>
    {
      nav.logoDataUrl ? (
        <img class="bundle-logo" src={nav.logoDataUrl} alt={`${nav.pkg} logo`} />
      ) : (
        <span class="bundle-logo bundle-logo-empty" aria-hidden="true">
          {nav.pkg.slice(0, 2).toUpperCase()}
        </span>
      )
    }
    <span class="bundle-identity-text">
      <span class="bundle-identity-pkg">{nav.pkg}</span>
      <span class="bundle-identity-version">{nav.version}</span>
    </span>
  </a>

  {summary ? <p class="bundle-summary">{summary}</p> : null}

  {
    hasToc || nav.docs.length > 0 ? (
      <nav class="sidebar-section">
        <h3 class="sidebar-heading">
          {nav.docsIndexHref ? <a href={nav.docsIndexHref}>Docs</a> : "Docs"}
        </h3>
        {hasToc ? (
          <ul class="sidebar-toc">
            {nav.toc.map((item) => (
              <li class={isTocActive(item) ? "is-active" : undefined}>
                {item.href ? <a href={item.href}>{item.title}</a> : <span>{item.title}</span>}
                {item.children.length > 0 && isTocSectionExpanded(item) ? (
                  <ul class="sidebar-toc">
                    {item.children.map((child) => (
                      <li class={isTocActive(child) ? "is-active" : undefined}>
                        {child.href ? (
                          <a href={child.href}>{child.title}</a>
                        ) : (
                          <span>{child.title}</span>
                        )}
                      </li>
                    ))}
                  </ul>
                ) : null}
              </li>
            ))}
          </ul>
        ) : (
          <ul class="sidebar-flat">
            {nav.docs.map((e) => (
              <li class={isDocActive(e.name) ? "is-active" : undefined}>
                <a href={e.href}>{labelForEntry(e)}</a>
              </li>
            ))}
          </ul>
        )}
      </nav>
    ) : null
  }

  {
    nav.tutorials.length > 0 ? (
      <nav class="sidebar-section">
        <h3 class="sidebar-heading">Tutorials</h3>
        <ul class="sidebar-flat">
          {nav.tutorials.map((e) => (
            <li class={isDocActive(e.name) ? "is-active" : undefined}>
              <a href={e.href}>{labelForEntry(e)}</a>
            </li>
          ))}
        </ul>
      </nav>
    ) : null
  }

  {
    nav.examples.length > 0 ? (
      <nav class="sidebar-section">
        <h3 class="sidebar-heading">Examples</h3>
        <ul class="sidebar-flat">
          {nav.examples.map((e) => (
            <li class={isExampleActive(e.name) ? "is-active" : undefined}>
              <a href={e.href}>{labelForEntry(e)}</a>
            </li>
          ))}
        </ul>
      </nav>
    ) : null
  }

  <nav class="sidebar-section">
    <h3 class="sidebar-heading">Browse</h3>
    <ul class="sidebar-flat">
      <li><a href={`/${nav.pkg}/${nav.version}/images/`}>Images</a></li>
      <li><a href={`/${nav.pkg}/${nav.version}/nodes/math/`}>Math</a></li>
      <li><a href={`/${nav.pkg}/${nav.version}/nodes/code/`}>Code</a></li>
      <li><a href={`/${nav.pkg}/${nav.version}/nodes/`}>All nodes</a></li>
    </ul>
  </nav>

  <nav class="sidebar-section sidebar-api">
    <h3 class="sidebar-heading">API</h3>
    <BundleSearch client:load pkg={nav.pkg} ver={nav.version} />
    <ul class="sidebar-qualnames">
      {
        apiTreeItems.map((item) => (
          <li
            class={item.isActive ? "is-active" : item.isAncestor ? "is-ancestor" : undefined}
            style={item.depth > 1 ? `--tree-depth: ${item.depth}` : undefined}
          >
            <a
              href={`/${nav.pkg}/${nav.version}/${qualnameToSlug(item.qualname)}/`}
              title={item.qualname}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>
