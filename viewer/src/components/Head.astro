---
// Shared <head> fragments used by every page.
//
// - Inlines a synchronous theme-priming script so the browser sets
//   `data-theme="dark"` on <html> before first paint (reading localStorage
//   via the key that matches `src/lib/theme.ts#THEME_STORAGE_KEY`).
// - Links the KaTeX CSS (needed by math-rendering pages; harmless elsewhere).
//
// The inline script is intentionally hand-rolled so it doesn't need to ship
// through a bundler — Astro emits it verbatim with `is:inline`.
import { THEME_STORAGE_KEY } from "../lib/theme.ts";
import { HIDE_TYPES_KEY, HIDE_PRIVATE_KEY } from "../lib/visibility.ts";

export interface Props {
  title: string;
}

const { title } = Astro.props;

// Note: keys are stringified so edits to the constants propagate automatically.
const themeInit = `
try {
  var t = localStorage.getItem(${JSON.stringify(THEME_STORAGE_KEY)});
  if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
  var r = document.documentElement;
  if (localStorage.getItem(${JSON.stringify(HIDE_TYPES_KEY)}) === '1') r.setAttribute('data-hide-types', '');
  if (localStorage.getItem(${JSON.stringify(HIDE_PRIVATE_KEY)}) === '1') r.setAttribute('data-hide-private', '');
} catch (e) {}
`.trim();
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<link rel="icon" type="image/png" href="/favicon.png" />
<script is:inline set:html={themeInit} />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
