---
// Thin wrapper around lib/render-node.ts so Astro pages can use a component.
// All dispatch logic lives in render-node.ts; this file just calls it and
// injects the resulting HTML string.
import type { IRNode } from "../lib/ir-reader.ts";
import { renderNode, type XRefResolver } from "../lib/render-node.ts";

const { node, resolveXref } = Astro.props as {
  node: IRNode;
  resolveXref?: XRefResolver;
};

const html = await renderNode(node, { resolveXref });
---

<Fragment set:html={html} />
