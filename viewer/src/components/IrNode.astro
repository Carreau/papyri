---
// Recursive renderer for papyri IR nodes.
// M1 scope: handles the block/inline subset produced by typical numpydoc
// sections (Paragraph, Text, Emphasis, Strong, Link, InlineCode, Code,
// BulletList, ListItem, Param, Parameters, XRef). Anything else falls
// through to a <details><pre>JSON</pre> dump so the page still renders.
//
// M2 adds XRef -> real <a href> resolution. The resolver is passed in as
// a prop (closes over the opened SQLite DB in the page frontmatter) rather
// than looked up here, so the DB handle is opened once per build. The same
// resolver is threaded through recursive Astro.self calls.
import type { IRNode } from "../lib/ir-reader.ts";
import { renderMath } from "../lib/math.ts";
import { highlight } from "../lib/highlight.ts";

export interface XRefResolution {
  url: string;
  label: string;
}

type Resolver = (node: unknown) => XRefResolution | null;

const { node, resolveXref } = Astro.props as {
  node: IRNode;
  resolveXref?: Resolver;
};

function asArray(x: unknown): IRNode[] {
  return Array.isArray(x) ? (x as IRNode[]) : [];
}

// Flatten XRef description: SeeAlsoItem descriptions contain Paragraphs.
const type = node && (node as { __type?: string }).__type;

const xrefResolved =
  type === "XRef" && resolveXref ? resolveXref(node) : null;

// Pre-render KaTeX / Shiki output here so the template below can use
// `set:html`. Astro frontmatter is async, so top-level await is legal.
const mathHtml =
  type === "Math"
    ? renderMath(String((node as any).value ?? ""), true)
    : type === "InlineMath"
      ? renderMath(String((node as any).value ?? ""), false)
      : null;

// IR Code nodes don't carry a language tag (see papyri/nodes.py:228), so
// default to python. The `highlight` helper handles its own errors.
const codeHtml =
  type === "Code"
    ? await highlight(String((node as any).value ?? ""), "python")
    : null;
---

{
  type === "Text" ? (
    <Fragment>{(node as any).value}</Fragment>
  ) : type === "Paragraph" ? (
    <p>
      {asArray((node as any).children).map((c) => (
        <Astro.self node={c} resolveXref={resolveXref} />
      ))}
    </p>
  ) : type === "Emphasis" ? (
    <em>
      {asArray((node as any).children).map((c) => (
        <Astro.self node={c} resolveXref={resolveXref} />
      ))}
    </em>
  ) : type === "Strong" ? (
    <strong>
      {asArray((node as any).children).map((c) => (
        <Astro.self node={c} resolveXref={resolveXref} />
      ))}
    </strong>
  ) : type === "InlineCode" ? (
    <code>{(node as any).value}</code>
  ) : type === "Code" ? (
    <pre class="code" set:html={codeHtml ?? ""}></pre>
  ) : type === "Link" ? (
    <a href={(node as any).url} title={(node as any).title}>
      {asArray((node as any).children).map((c) => (
        <Astro.self node={c} resolveXref={resolveXref} />
      ))}
    </a>
  ) : type === "BulletList" ? (
    <ul>
      {asArray((node as any).children).map((c) => (
        <Astro.self node={c} resolveXref={resolveXref} />
      ))}
    </ul>
  ) : type === "ListItem" ? (
    <li>
      {asArray((node as any).children).map((c) => (
        <Astro.self node={c} resolveXref={resolveXref} />
      ))}
    </li>
  ) : type === "Blockquote" ? (
    <blockquote>
      {asArray((node as any).children).map((c) => (
        <Astro.self node={c} resolveXref={resolveXref} />
      ))}
    </blockquote>
  ) : type === "ThematicBreak" ? (
    <hr />
  ) : type === "Heading" ? (
    <h3>
      {asArray((node as any).children).map((c) => (
        <Astro.self node={c} resolveXref={resolveXref} />
      ))}
    </h3>
  ) : type === "Math" ? (
    <div class="math" set:html={mathHtml ?? ""}></div>
  ) : type === "InlineMath" ? (
    <span class="math" set:html={mathHtml ?? ""}></span>
  ) : type === "Parameters" ? (
    <dl class="params">
      {asArray((node as any).children).map((p) => (
        <Astro.self node={p} resolveXref={resolveXref} />
      ))}
    </dl>
  ) : type === "Param" ? (
    <Fragment>
      <dt>
        <code class="pname">{(node as any).param}</code>
        {(node as any).type_ ? (
          <span class="ptype"> : {(node as any).type_}</span>
        ) : null}
      </dt>
      <dd>
        {asArray((node as any).desc).map((c) => (
          <Astro.self node={c} resolveXref={resolveXref} />
        ))}
      </dd>
    </Fragment>
  ) : type === "XRef" ? (
    xrefResolved ? (
      <a class="xref" href={xrefResolved.url}>{xrefResolved.label}</a>
    ) : (
      <span class="xref unresolved">{(node as any).value}</span>
    )
  ) : type === "Section" ? (
    <div>
      {asArray((node as any).children).map((c) => (
        <Astro.self node={c} resolveXref={resolveXref} />
      ))}
    </div>
  ) : type === "Admonition" ? (
    <aside class={`admonition ${(node as any).kind ?? "note"}`}>
      {asArray((node as any).children).map((c) => (
        <Astro.self node={c} resolveXref={resolveXref} />
      ))}
    </aside>
  ) : type === "AdmonitionTitle" ? (
    <p class="admonition-title">
      {asArray((node as any).children).map((c) => (
        <Astro.self node={c} resolveXref={resolveXref} />
      ))}
    </p>
  ) : type === "InlineRole" ? (
    // Inline cross-references like `:py:class:`X`` or `:func:`foo``. The
    // graph resolves XRef, not InlineRole, so for now we render as styled
    // inline code with the role as a CSS class hook. Tracked as a future
    // refinement when/if the IR gets cross-referenced InlineRoles.
    <code
      class={`role ${(node as any).domain ? `role-${(node as any).domain}` : ""} ${(node as any).role ? `role-name-${(node as any).role}` : ""}`.trim()}
    >
      {(node as any).value}
    </code>
  ) : type === "DefList" ? (
    <dl class="deflist">
      {asArray((node as any).children).map((c) => (
        <Astro.self node={c} resolveXref={resolveXref} />
      ))}
    </dl>
  ) : type === "DefListItem" ? (
    <Fragment>
      <dt>
        <Astro.self node={(node as any).dt} resolveXref={resolveXref} />
      </dt>
      <dd>
        {asArray((node as any).dd).map((c) => (
          <Astro.self node={c} resolveXref={resolveXref} />
        ))}
      </dd>
    </Fragment>
  ) : type === "FieldList" ? (
    <dl class="fieldlist">
      {asArray((node as any).children).map((c) => (
        <Astro.self node={c} resolveXref={resolveXref} />
      ))}
    </dl>
  ) : type === "FieldListItem" ? (
    <Fragment>
      <dt>
        {asArray((node as any).name).map((c) => (
          <Astro.self node={c} resolveXref={resolveXref} />
        ))}
      </dt>
      <dd>
        {asArray((node as any).body).map((c) => (
          <Astro.self node={c} resolveXref={resolveXref} />
        ))}
      </dd>
    </Fragment>
  ) : type === "Directive" ? (
    // Processed directives the gen/ingest pass couldn't rewrite into a more
    // specific node (Math, Admonition, etc.). Render as an admonition-like
    // block so the content is visible; show the directive name as a tag.
    <aside class={`directive directive-${(node as any).name ?? "unknown"}`}>
      <p class="directive-name">
        <code>:{(node as any).name}:</code>
        {(node as any).args ? <span class="directive-args">{(node as any).args}</span> : null}
      </p>
      {asArray((node as any).children).map((c) => (
        <Astro.self node={c} resolveXref={resolveXref} />
      ))}
    </aside>
  ) : type === "Image" ? (
    <img src={(node as any).url} alt={(node as any).alt ?? ""} />
  ) : type === "Fig" ? (
    // Fig.value is a RefInfo(module, version, kind="assets", path=filename).
    // We don't currently serve assets from the viewer, so just show a
    // placeholder with the asset path for now. Tracked as M3 follow-up.
    <figure class="fig">
      <code class="role">asset: {(node as any).value?.path ?? "?"}</code>
    </figure>
  ) : type === "Target" ? (
    <span id={(node as any).label} class="target" />
  ) : type === "Comment" ? (
    null
  ) : type === "SubstitutionRef" || type === "SubstitutionDef" ? (
    // Substitutions aren't resolved yet — render the substitution body if any
    // so the reader sees something. Tracked in viewer/PLAN.md follow-ups.
    <span class="substitution">
      {(node as any).value ?? ""}
    </span>
  ) : type === "UnimplementedInline" ? (
    <span class="unimplemented">
      {asArray((node as any).children).map((c) => (
        <Astro.self node={c} resolveXref={resolveXref} />
      ))}
    </span>
  ) : type === "Unimplemented" ? (
    <div class="unimplemented">
      {(node as any).placeholder ? <code>{(node as any).placeholder}</code> : null}
      {(node as any).value ? <span>{(node as any).value}</span> : null}
    </div>
  ) : (
    <details class="fallback">
      <summary>unhandled: {type ?? "raw"}</summary>
      <pre>{JSON.stringify(node, null, 2)}</pre>
    </details>
  )
}
