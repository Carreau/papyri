---
import type { SignatureNodeT, SigParamT } from "../lib/ir-reader.ts";

interface Props {
  signature: SignatureNodeT;
}

const { signature } = Astro.props;

function annText(
  ann: SigParamT["annotation"] | SignatureNodeT["return_annotation"]
): string | null {
  if (ann == null) return null;
  if (typeof ann === "string") return ann;
  return null;
}

function defaultText(def: SigParamT["default"]): string | null {
  if (def == null) return null;
  if (typeof def === "string") return def;
  return null;
}

// Split parameters into (marker, param) pairs so we can emit the `/` and `*`
// grouping separators at structural boundaries instead of inline in a string.
//   POSITIONAL_ONLY → followed by `/` on the next non-positional-only param
//   KEYWORD_ONLY    → preceded by `*` if no VAR_POSITIONAL already provided one
type Kind = SigParamT["kind"];
interface Entry {
  marker: "/" | "*" | null;
  param: SigParamT;
}
const entries: Entry[] = [];
let prevKind: Kind | null = null;
let sawVarPositional = false;
for (const p of signature.parameters) {
  let marker: Entry["marker"] = null;
  if (prevKind === "POSITIONAL_ONLY" && p.kind !== "POSITIONAL_ONLY") {
    marker = "/";
  } else if (p.kind === "KEYWORD_ONLY" && prevKind !== "KEYWORD_ONLY" && !sawVarPositional) {
    marker = "*";
  }
  entries.push({ marker, param: p });
  if (p.kind === "VAR_POSITIONAL") sawVarPositional = true;
  prevKind = p.kind;
}
// Trailing `/` if the last parameter was positional-only.
const trailingSlash = prevKind === "POSITIONAL_ONLY";

const returnAnn = annText(signature.return_annotation);
---

<div class="sig" role="group" aria-label="Function signature">
  <code class="sig-code">
    <span class="sig-name">{signature.target_name}</span>
    <span class="sig-punct">(</span>
    {
      entries.map((e, i) => (
        <>
          {e.marker ? (
            <>
              <span class="sig-marker">{e.marker}</span>
              <span class="sig-punct">, </span>
            </>
          ) : null}
          <span class={`sig-param sig-kind-${e.param.kind.toLowerCase()}`}>
            {e.param.kind === "VAR_POSITIONAL" ? <span class="sig-stars">*</span> : null}
            {e.param.kind === "VAR_KEYWORD" ? <span class="sig-stars">**</span> : null}
            <span class="sig-param-name">{e.param.name}</span>
            {annText(e.param.annotation) ? (
              <>
                <span class="sig-punct">: </span>
                <span class="sig-annotation">{annText(e.param.annotation)}</span>
              </>
            ) : null}
            {defaultText(e.param.default) != null ? (
              <>
                <span class="sig-punct">{annText(e.param.annotation) ? " = " : "="}</span>
                <span class="sig-default">{defaultText(e.param.default)}</span>
              </>
            ) : null}
          </span>
          {i < entries.length - 1 ? <span class="sig-punct">, </span> : null}
        </>
      ))
    }
    {
      trailingSlash ? (
        <>
          <span class="sig-punct">, </span>
          <span class="sig-marker">/</span>
        </>
      ) : null
    }
    <span class="sig-punct">)</span>
    {
      returnAnn ? (
        <>
          <span class="sig-arrow"> → </span>
          <span class="sig-return">{returnAnn}</span>
        </>
      ) : null
    }
  </code>
</div>
