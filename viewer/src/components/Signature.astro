---
import type { SignatureNodeT } from "../lib/ir-reader.ts";
import {
  annText,
  buildSignatureEntries,
  defaultText,
  sigKindBadge,
  sigQualifier,
} from "../lib/signature.ts";

interface Props {
  signature: SignatureNodeT;
  itemType: string | null;
}

const { signature, itemType } = Astro.props;
const { entries, trailingSlash } = buildSignatureEntries(signature);
const returnAnn = annText(signature.return_annotation);
const qualifier = sigQualifier(signature.kind, itemType);
const kindBadge = sigKindBadge(signature.kind, itemType);
---

<div class="sig" role="group" aria-label="Function signature">
  {kindBadge && <span class="sig-kind-badge">{kindBadge}</span>}
  <code class="sig-code">
    {
      qualifier && (
        <>
          <>
            <span class="sig-qualifier">{qualifier}</span>
            <span class="sig-qualifier-space">&nbsp;</span>
          </>
        </>
      )
    }
    <span class="sig-name">{signature.target_name}</span>
    <span class="sig-punct">(</span>
    {
      entries.map((e, i) => (
        <>
          {e.marker ? (
            <>
              <span class="sig-marker">{e.marker}</span>
              <span class="sig-punct">,&nbsp;</span>
            </>
          ) : null}
          <span
            class={`sig-param sig-kind-${e.param.kind.toLowerCase()}`}
            data-param={e.param.name}
          >
            {e.param.kind === "VAR_POSITIONAL" ? <span class="sig-stars">*</span> : null}
            {e.param.kind === "VAR_KEYWORD" ? <span class="sig-stars">**</span> : null}
            <span class="sig-param-name">{e.param.name}</span>
            {annText(e.param.annotation) ? (
              <>
                <span class="sig-punct">: </span>
                <span class="sig-annotation">{annText(e.param.annotation)}</span>
              </>
            ) : null}
            {defaultText(e.param.default) != null ? (
              <>
                <span class="sig-punct"> = </span>
                <span class="sig-default">{defaultText(e.param.default)}</span>
              </>
            ) : null}
          </span>
          {i < entries.length - 1 ? <span class="sig-punct">,&nbsp;</span> : null}
        </>
      ))
    }
    {
      trailingSlash ? (
        <>
          <span class="sig-punct">,&nbsp;</span>
          <span class="sig-marker">/</span>
        </>
      ) : null
    }
    <span class="sig-punct">)</span>
    {
      returnAnn ? (
        <>
          <span class="sig-arrow">&nbsp;→&nbsp;</span>
          <span class="sig-return">{returnAnn}</span>
        </>
      ) : null
    }
  </code>
</div>

<script>
  // Highlight all param-ref tokens and the matching sig-param on hover.
  // Uses event delegation on document so it works after Astro view transitions.
  function paramHighlight(e: Event) {
    const target = e.target as HTMLElement | null;
    if (!target) return;
    const ref = target.closest<HTMLElement>("[data-param]");
    const name = ref?.dataset.param;
    if (!name) return;

    const active = e.type === "mouseenter" || e.type === "focusin";
    document
      .querySelectorAll<HTMLElement>(`[data-param="${CSS.escape(name)}"]`)
      .forEach((el) => el.classList.toggle("param-highlight", active));
  }

  document.addEventListener("mouseenter", paramHighlight, true);
  document.addEventListener("mouseleave", paramHighlight, true);
  document.addEventListener("focusin", paramHighlight, true);
  document.addEventListener("focusout", paramHighlight, true);
</script>
