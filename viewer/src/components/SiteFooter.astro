---
// Site-wide footer. Renders only when at least one of the PAPYRI_FOOTER_*
// build-time env vars is set; invisible (zero height) otherwise.
//
// Env vars (set at build time via the host environment):
//   PAPYRI_FOOTER_COPYRIGHT  — copyright line, e.g. "© 2025 Acme Corp."
//   PAPYRI_FOOTER_PRIVACY_URL — URL for a "Privacy policy" link
//   PAPYRI_FOOTER_TERMS_URL   — URL for a "Terms of service" link
//
// All are optional. When none are set the <footer> element is rendered but
// empty so callers do not need to guard around the component.
const copyright = import.meta.env.PAPYRI_FOOTER_COPYRIGHT ?? "";
const privacyUrl = import.meta.env.PAPYRI_FOOTER_PRIVACY_URL ?? "";
const termsUrl = import.meta.env.PAPYRI_FOOTER_TERMS_URL ?? "";

const hasContent = copyright || privacyUrl || termsUrl;
---

{
  hasContent && (
    <footer class="site-footer">
      {copyright && <span class="site-footer-copyright">{copyright}</span>}
      {(privacyUrl || termsUrl) && (
        <nav class="site-footer-links" aria-label="Legal">
          {privacyUrl && (
            <a href={privacyUrl} class="site-footer-link">
              Privacy policy
            </a>
          )}
          {termsUrl && (
            <a href={termsUrl} class="site-footer-link">
              Terms of service
            </a>
          )}
        </nav>
      )}
    </footer>
  )
}

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 0.75rem 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1.5rem;
    font-size: 0.8rem;
    color: var(--fg-muted);
    background: var(--surface);
  }

  .site-footer-links {
    display: flex;
    gap: 1rem;
  }

  .site-footer-link {
    color: var(--fg-muted);
    text-decoration: none;
  }

  .site-footer-link:hover {
    color: var(--accent);
    text-decoration: underline;
  }
</style>
