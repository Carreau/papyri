---
// Two-column shell for every page under /[pkg]/[ver]/**. Loads the bundle
// view-model once per page (memoised in `nav.ts`) and hands it to the
// sidebar so callers don't repeat the frontmatter.
import Head from "../components/Head.astro";
import SiteHeader from "../components/SiteHeader.astro";
import BundleSidebar from "../components/BundleSidebar.astro";
import { loadBundleNav } from "../lib/nav.ts";
import { resolveVersion } from "../lib/ir-reader.ts";
import { getBackends } from "../lib/backends.ts";
import "../styles/global.css";

interface Props {
  pkg: string;
  ver: string;
  title: string;
  activeQualname?: string;
  activeDocPath?: string;
  activeExamplePath?: string;
  hasToc?: boolean;
  /** Resolved actual version for blob reads when `ver` is "latest". */
  actualVer?: string;
}

const {
  pkg,
  ver,
  title,
  activeQualname,
  activeDocPath,
  activeExamplePath,
  hasToc,
  actualVer: propActualVer,
} = Astro.props;
const { blobStore, graphDb } = await getBackends();
const actualVer = propActualVer ?? (await resolveVersion(graphDb, pkg, ver)) ?? ver;
const nav = await loadBundleNav(blobStore, pkg, actualVer, ver);
---

<html lang="en">
  <head>
    <Head title={title} />
  </head>
  <body>
    <SiteHeader />
    <div class:list={["bundle-layout", hasToc && "has-page-toc"]}>
      <input type="checkbox" id="sidebar-toggle" class="sidebar-toggle-cb" aria-hidden="true" />
      <input type="checkbox" id="sidebar-collapse" class="sidebar-collapse-cb" aria-hidden="true" />
      {
        hasToc && (
          <input type="checkbox" id="toc-collapse" class="toc-collapse-cb" aria-hidden="true" />
        )
      }
      <label for="sidebar-toggle" class="sidebar-toggle-label">
        <span class="sidebar-toggle-open" aria-hidden="true">&#9776;</span>
        <span class="sidebar-toggle-close" aria-hidden="true">&times;</span>
        <span class="sidebar-toggle-text">Navigation</span>
      </label>
      <label
        for="sidebar-collapse"
        class="sidebar-collapse-label"
        title="Collapse navigation"
        aria-label="Collapse navigation sidebar"
      >
        <span class="collapse-icon-collapse" aria-hidden="true">&#x2B05;</span>
        <span class="collapse-icon-expand" aria-hidden="true">&#x2B95;</span>
      </label>
      {
        hasToc && (
          <label
            for="toc-collapse"
            class="toc-collapse-label"
            title="Collapse on-this-page"
            aria-label="Collapse on-this-page panel"
          >
            <span class="collapse-icon-collapse" aria-hidden="true">
              &#x2B95;
            </span>
            <span class="collapse-icon-expand" aria-hidden="true">
              &#x2B05;
            </span>
          </label>
        )
      }
      <BundleSidebar
        nav={nav}
        activeQualname={activeQualname}
        activeDocPath={activeDocPath}
        activeExamplePath={activeExamplePath}
      />
      <main class="bundle-main">
        <slot />
      </main>
      {
        hasToc && (
          <aside class="page-toc-panel" aria-label="On this page">
            <slot name="page-toc" />
          </aside>
        )
      }
    </div>
  </body>
</html>
