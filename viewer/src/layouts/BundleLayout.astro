---
// Two-column shell for every page under /[pkg]/[ver]/**. Loads the bundle
// view-model once per page (memoised in `nav.ts`) and hands it to the
// sidebar so callers don't repeat the frontmatter.
import Head from "../components/Head.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import BundleSidebar from "../components/BundleSidebar.astro";
import VersionBanner from "../components/VersionBanner.astro";
import { loadBundleNav } from "../lib/nav.ts";
import { resolveVersion, listIngestedPackages } from "../lib/ir-reader.ts";
import { getBackends } from "../lib/backends.ts";
import { getVersionStatus, equivalentLatestHref } from "../lib/version-utils.ts";
import { getVersionDigests } from "../lib/graph.ts";
import { linkForQualname, linkForDoc, linkForExample } from "../lib/links.ts";
import "../styles/global.css";

interface Props {
  pkg: string;
  ver: string;
  title: string;
  activeQualname?: string;
  activeDocPath?: string;
  activeExamplePath?: string;
  hasToc?: boolean;
  /** Resolved actual version for blob reads when `ver` is "latest". */
  actualVer?: string;
  /** Blob kind + path backing this page; when both set, a "Raw JSON" link
   * to the decoded IR is shown. Only the single-blob pages (module / docs /
   * examples) pass these. */
  rawKind?: "module" | "docs" | "examples";
  rawPath?: string;
}

const {
  pkg,
  ver,
  title,
  activeQualname,
  activeDocPath,
  activeExamplePath,
  hasToc,
  actualVer: propActualVer,
  rawKind,
  rawPath,
} = Astro.props;
const rawJsonHref =
  rawKind && rawPath
    ? `/api/${pkg}/${ver}/raw.json?kind=${rawKind}&path=${encodeURIComponent(rawPath)}`
    : null;
const { blobStore, graphDb } = await getBackends();
const actualVer = propActualVer ?? (await resolveVersion(graphDb, pkg, ver)) ?? ver;

// Fetch all versions for the package plus, for single-blob pages, the
// per-identifier content digests used to group identical versions.
const digestCategory = rawKind === "module" ? "module" : rawKind === "docs" ? "docs" : null;
const [nav, versionStatus, allPkgs, digestMap] = await Promise.all([
  loadBundleNav(blobStore, pkg, actualVer, ver),
  getVersionStatus(graphDb, pkg, actualVer),
  listIngestedPackages(graphDb),
  digestCategory && rawPath
    ? getVersionDigests(graphDb, pkg, digestCategory, rawPath)
    : Promise.resolve(new Map<string, string>()),
]);

// All ingested versions for this package, sorted oldest → newest.
// listIngestedPackages returns them latest-first, so reverse.
const pkgVersions = [...(allPkgs.find((p) => p.pkg === pkg)?.versions ?? [actualVer])].reverse();

// Build the switcher version list: every package version with a content
// group key. Pages with digest data use the BLAKE2b hex as the group so
// identical versions cluster; other pages (and versions missing this page)
// fall back to the version string itself (each a singleton group).
const switcherVersions = pkgVersions.map((v) => ({
  v,
  group: digestMap.get(v) ?? v,
}));

// Per-version navigation href. For single-blob pages, go to the same page
// in that version; for everything else (bundle index, search, …) go to the
// bundle root in that version.
const switcherHrefs: Record<string, string> = Object.fromEntries(
  pkgVersions.map((v) => [
    v,
    rawKind === "module" && rawPath
      ? linkForQualname(pkg, v, rawPath)
      : rawKind === "docs" && rawPath
        ? linkForDoc(pkg, v, rawPath)
        : rawKind === "examples" && rawPath
          ? linkForExample(pkg, v, rawPath)
          : `/project/${pkg}/${v}/`,
  ])
);

// When browsing an older/dev/pre version, point "Go to latest" at the same
// page in the latest version (falling back to the bundle root inside the
// banner when there is no equivalent page).
let latestHref: string | null = null;
if (versionStatus.kind !== "latest" && versionStatus.latestVersion) {
  latestHref = await equivalentLatestHref(blobStore, pkg, versionStatus.latestVersion, {
    qualname: activeQualname,
    docPath: activeDocPath,
    examplePath: activeExamplePath,
  });
}
---

<html lang="en">
  <head>
    <Head title={title} />
  </head>
  <body>
    <SiteHeader />
    <div class:list={["bundle-layout", hasToc && "has-page-toc"]}>
      <input type="checkbox" id="sidebar-toggle" class="sidebar-toggle-cb" aria-hidden="true" />
      <input type="checkbox" id="sidebar-collapse" class="sidebar-collapse-cb" aria-hidden="true" />
      {
        hasToc && (
          <input type="checkbox" id="toc-collapse" class="toc-collapse-cb" aria-hidden="true" />
        )
      }
      <label for="sidebar-toggle" class="sidebar-toggle-label">
        <span class="sidebar-toggle-open" aria-hidden="true">&#9776;</span>
        <span class="sidebar-toggle-close" aria-hidden="true">&times;</span>
        <span class="sidebar-toggle-text">Navigation</span>
      </label>
      <label
        for="sidebar-collapse"
        class="sidebar-collapse-label"
        title="Collapse navigation"
        aria-label="Collapse navigation sidebar"
      >
        <span class="collapse-icon-collapse" aria-hidden="true">&#x2B05;</span>
        <span class="collapse-icon-expand" aria-hidden="true">&#x2B95;</span>
      </label>
      {
        hasToc && (
          <label
            for="toc-collapse"
            class="toc-collapse-label"
            title="Collapse on-this-page"
            aria-label="Collapse on-this-page panel"
          >
            <span class="collapse-icon-collapse" aria-hidden="true">
              &#x2B95;
            </span>
            <span class="collapse-icon-expand" aria-hidden="true">
              &#x2B05;
            </span>
          </label>
        )
      }
      <BundleSidebar
        nav={nav}
        activeQualname={activeQualname}
        activeDocPath={activeDocPath}
        activeExamplePath={activeExamplePath}
        switcherVersions={switcherVersions}
        switcherCurrent={actualVer}
        switcherHrefs={switcherHrefs}
      />
      <main class="bundle-main">
        {
          versionStatus.kind !== "latest" && (
            <VersionBanner pkg={pkg} ver={ver} status={versionStatus} latestHref={latestHref} />
          )
        }
        {
          rawJsonHref && (
            <a class="raw-json-link" href={rawJsonHref} target="_blank" rel="noopener">
              {"{ }"} Raw JSON
            </a>
          )
        }
        <slot />
      </main>
      {
        hasToc && (
          <aside class="page-toc-panel" aria-label="On this page">
            <slot name="page-toc" />
          </aside>
        )
      }
    </div>
    <SiteFooter />
  </body>
</html>

<style>
  .raw-json-link {
    float: right;
    margin-left: 1rem;
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--fg-muted);
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1rem 0.5rem;
  }
  .raw-json-link:hover {
    color: var(--accent);
    border-color: currentColor;
  }
</style>
