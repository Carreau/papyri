---
// Astro serves this in dev for unknown routes and most static hosts
// (GitHub Pages, Netlify, nginx with try_files) pick up `/404.html` from
// the built output as the not-found body. No React island — keep this page
// as close to a static HTML document as possible so it renders even if
// something's badly broken elsewhere in the site.
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not found — Papyri viewer">
  <p class="crumb"><a href="/">&larr; bundles</a></p>
  <h1>Page not found</h1>
  <p class="lede">
    This URL doesn&apos;t match any ingested bundle or qualname. It may have moved between papyri
    versions, or the bundle hasn&apos;t been ingested on this site.
  </p>
  <p>
    Head back to <a href="/">the bundle index</a> and browse from there.
  </p>
</BaseLayout>
