---
import { join } from "node:path";
import {
  ingestDir,
  loadModule,
  sectionChildren,
  slugToQualname,
  type IngestedDoc,
} from "../../../lib/ir-reader.ts";
import { getBackrefs } from "../../../lib/graph.ts";
import { buildQualnamePageView } from "../../../lib/qualname-page.ts";
import { resolveXref } from "../../../lib/xref.ts";
import IrNode from "../../../components/IrNode.astro";
import Signature from "../../../components/Signature.astro";
import BundleLayout from "../../../layouts/BundleLayout.astro";

export const prerender = false;

const { pkg, ver, slug } = Astro.params;

if (!pkg || !ver || slug === undefined) {
  return new Response("Not found", { status: 404 });
}

const qualname = slugToQualname(slug);
const bundlePath = join(ingestDir(), pkg, ver);

let doc: IngestedDoc;
try {
  doc = await loadModule(bundlePath, qualname);
} catch {
  return new Response(`Module ${qualname} not found`, { status: 404 });
}

const backrefs = getBackrefs({ pkg, ver, kind: "module", path: qualname });
const view = buildQualnamePageView(doc, backrefs, pkg);
const hasBackrefs = view.internalBackrefs.length > 0 || view.externalBackrefs.length > 0;
---

<BundleLayout
  pkg={pkg!}
  ver={ver!}
  bundlePath={bundlePath}
  title={`${qualname} — Papyri viewer`}
  activeQualname={qualname}
>
  <p class="crumb">
    <a href="/">bundles</a> / <a href={`/${pkg}/${ver}/`}>{pkg} {ver}</a>
  </p>

  <header class="qa-header">
    {doc.item_type ? <p class="kind">{doc.item_type}</p> : null}
    <h1><code>{doc.qa}</code></h1>
    {
      doc.item_file ? (
        <p class="source">
          source: <code>{doc.item_file}</code>
          {doc.item_line != null ? <Fragment>:{doc.item_line}</Fragment> : null}
        </p>
      ) : null
    }
  </header>

  {
    doc.signature ? (
      <section class="signature">
        <h2>Signature</h2>
        <Signature signature={doc.signature} />
      </section>
    ) : null
  }

  {
    view.sections.map(({ title, section }) => (
      <section class={`doc-section doc-section-${title.toLowerCase().replace(/\s+/g, "-")}`}>
        <h2>{title}</h2>
        {sectionChildren(section).map((c) => (
          <IrNode node={c} resolveXref={resolveXref} />
        ))}
      </section>
    ))
  }

  {
    view.arbitrary.length > 0 ? (
      <section class="doc-section doc-section-arbitrary">
        <h2>Additional content</h2>
        {view.arbitrary.map((s) => (
          <div>
            {s.title ? <h3>{s.title}</h3> : null}
            {sectionChildren(s).map((c) => (
              <IrNode node={c} resolveXref={resolveXref} />
            ))}
          </div>
        ))}
      </section>
    ) : null
  }

  {
    view.exampleSection ? (
      <section class="doc-section doc-section-examples">
        <h2>{view.exampleSection.title}</h2>
        {view.exampleSection.children.map((c) => (
          <IrNode node={c} resolveXref={resolveXref} />
        ))}
      </section>
    ) : null
  }

  {
    doc.aliases && doc.aliases.length > 0 ? (
      <section class="aliases">
        <h2>Aliases</h2>
        <ul>
          {doc.aliases.map((a) => (
            <li>
              <code>{a}</code>
            </li>
          ))}
        </ul>
      </section>
    ) : null
  }

  {
    hasBackrefs ? (
      <section class="backrefs">
        <h2>Referenced by</h2>
        {view.internalBackrefs.length > 0 ? (
          <div class="backref-group">
            <h3>This package</h3>
            <ul class="qualnames">
              {view.internalBackrefs.map((b) => (
                <li>
                  <a href={b.url}>{b.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ) : null}
        {view.externalBackrefs.length > 0 ? (
          <div class="backref-group">
            <h3>Other packages</h3>
            <ul class="qualnames qualnames-external">
              {view.externalBackrefs.map((b) => (
                <li>
                  <span class="backref-pkg">{b.pkg}</span>
                  <a href={b.url}>{b.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ) : null}
      </section>
    ) : null
  }
</BundleLayout>
