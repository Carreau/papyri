---
import {
  loadModule,
  sectionChildren,
  slugToQualname,
  type IngestedDoc,
} from "../../../lib/ir-reader.ts";
import { getBackrefs } from "../../../lib/graph.ts";
import { getBackends } from "../../../lib/backends.ts";
import { buildQualnamePageView } from "../../../lib/qualname-page.ts";
import { buildXrefResolver } from "../../../lib/xref.ts";
import { linkForQualname } from "../../../lib/links.ts";
import { loadBundleNav } from "../../../lib/nav.ts";
import { qualnameAncestors, qualnameLabel } from "../../../lib/qualname.ts";
import IrNode from "../../../components/IrNode.astro";
import Signature from "../../../components/Signature.astro";
import BundleLayout from "../../../layouts/BundleLayout.astro";

export const prerender = false;

const { pkg, ver, slug } = Astro.params;

if (!pkg || !ver || slug === undefined) {
  return new Response("Not found", { status: 404 });
}

const qualname = slugToQualname(slug);
const { blobStore, graphDb } = await getBackends();

let doc: IngestedDoc;
try {
  doc = await loadModule(blobStore, pkg, ver, qualname);
} catch {
  return new Response(`Module ${qualname} not found`, { status: 404 });
}

const backrefs = await getBackrefs(graphDb, { pkg, ver, kind: "module", path: qualname });
const view = buildQualnamePageView(doc, backrefs, pkg);
const hasBackrefs = view.internalBackrefs.length > 0 || view.externalBackrefs.length > 0;
const resolveXref = await buildXrefResolver(graphDb, doc, pkg, ver);

// Direct children for the on-page Members TOC. Qualnames use `:` to separate
// the module path from in-module objects, and `.` after `:` for class
// members. Examples:
//   `pkg.sub`               — submodule of `pkg`
//   `pkg.sub:func`          — function/class/attr inside module `pkg.sub`
//   `pkg.sub:Cls.method`    — method on class `pkg.sub:Cls`
const nav = await loadBundleNav(blobStore, pkg, ver);
const isClassPage = qualname.includes(":");
interface MemberGroup {
  title: string;
  items: { qualname: string; label: string; href: string }[];
}
const submodules: MemberGroup["items"] = [];
const moduleMembers: MemberGroup["items"] = [];
const classMembers: MemberGroup["items"] = [];

if (isClassPage) {
  const prefix = `${qualname}.`;
  for (const qa of nav.qualnames) {
    if (!qa.startsWith(prefix)) continue;
    const rest = qa.slice(prefix.length);
    if (rest.length === 0 || rest.includes(".") || rest.includes(":")) continue;
    classMembers.push({ qualname: qa, label: rest, href: linkForQualname(pkg, ver, qa) });
  }
} else {
  const dotPrefix = `${qualname}.`;
  const colonPrefix = `${qualname}:`;
  for (const qa of nav.qualnames) {
    if (qa.startsWith(dotPrefix)) {
      const rest = qa.slice(dotPrefix.length);
      if (rest.length === 0 || rest.includes(".") || rest.includes(":")) continue;
      submodules.push({ qualname: qa, label: rest, href: linkForQualname(pkg, ver, qa) });
    } else if (qa.startsWith(colonPrefix)) {
      const rest = qa.slice(colonPrefix.length);
      if (rest.length === 0 || rest.includes(".") || rest.includes(":")) continue;
      moduleMembers.push({ qualname: qa, label: rest, href: linkForQualname(pkg, ver, qa) });
    }
  }
}
const byLabel = (a: { label: string }, b: { label: string }) => a.label.localeCompare(b.label);
submodules.sort(byLabel);
moduleMembers.sort(byLabel);
classMembers.sort(byLabel);
const memberGroups: MemberGroup[] = isClassPage
  ? [{ title: "Members", items: classMembers }]
  : [
      { title: "Submodules", items: submodules },
      { title: "Members", items: moduleMembers },
    ];
const hasMembers = memberGroups.some((g) => g.items.length > 0);

const crumbs = qualnameAncestors(qualname).map((qa) => ({
  qualname: qa,
  label: qualnameLabel(qa),
  href: linkForQualname(pkg, ver, qa),
}));
---

<BundleLayout pkg={pkg} ver={ver} title={`${qualname} — Papyri viewer`} activeQualname={qualname}>
  <p class="crumb">
    <a href="/">bundles</a> / <a href={`/${pkg}/${ver}/`}>{pkg} {ver}</a>
    {
      crumbs.map((c, i) =>
        i === crumbs.length - 1 ? (
          <Fragment>
            {" / "}
            <span aria-current="page">
              <code>{c.label}</code>
            </span>
          </Fragment>
        ) : (
          <Fragment>
            {" / "}
            <a href={c.href} title={c.qualname}>
              <code>{c.label}</code>
            </a>
          </Fragment>
        )
      )
    }
  </p>

  <header class="qa-header">
    {doc.item_type ? <p class="kind">{doc.item_type}</p> : null}
    <h1><code>{doc.qa}</code></h1>
    {
      doc.item_file ? (
        <p class="source">
          source: <code>{doc.item_file}</code>
          {doc.item_line != null ? <Fragment>:{doc.item_line}</Fragment> : null}
        </p>
      ) : null
    }
  </header>

  {
    doc.signature ? (
      <section class="signature">
        <h2>Signature</h2>
        <Signature signature={doc.signature} />
      </section>
    ) : null
  }

  {
    hasMembers ? (
      <section class="doc-section doc-section-members">
        {memberGroups.map((group) =>
          group.items.length > 0 ? (
            <Fragment>
              <h2>{group.title}</h2>
              <ul class="qualnames members-toc">
                {group.items.map((m) => (
                  <li class={m.label.startsWith("_") ? "member-private" : undefined}>
                    <a href={m.href} title={m.qualname}>
                      <code>{m.label}</code>
                    </a>
                  </li>
                ))}
              </ul>
            </Fragment>
          ) : null
        )}
      </section>
    ) : null
  }

  {
    view.sections.map(({ title, section }) => (
      <section class={`doc-section doc-section-${title.toLowerCase().replace(/\s+/g, "-")}`}>
        <h2>{title}</h2>
        {sectionChildren(section).map((c) => (
          <IrNode node={c} resolveXref={resolveXref} />
        ))}
      </section>
    ))
  }

  {
    view.arbitrary.length > 0 ? (
      <section class="doc-section doc-section-arbitrary">
        <h2>Additional content</h2>
        {view.arbitrary.map((s) => (
          <div>
            {s.title ? <h3>{s.title}</h3> : null}
            {sectionChildren(s).map((c) => (
              <IrNode node={c} resolveXref={resolveXref} />
            ))}
          </div>
        ))}
      </section>
    ) : null
  }

  {
    view.exampleSection ? (
      <section class="doc-section doc-section-examples">
        <h2>{view.exampleSection.title}</h2>
        {view.exampleSection.children.map((c) => (
          <IrNode node={c} resolveXref={resolveXref} />
        ))}
      </section>
    ) : null
  }

  {
    doc.aliases && doc.aliases.length > 0 ? (
      <section class="aliases">
        <h2>Aliases</h2>
        <ul>
          {doc.aliases.map((a) => (
            <li>
              <code>{a}</code>
            </li>
          ))}
        </ul>
      </section>
    ) : null
  }

  {
    hasBackrefs ? (
      <section class="backrefs">
        <h2>Referenced by</h2>
        {view.internalBackrefs.length > 0 ? (
          <div class="backref-group">
            <h3>This package</h3>
            <ul class="qualnames">
              {view.internalBackrefs.map((b) => (
                <li>
                  <a href={b.url}>{b.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ) : null}
        {view.externalBackrefs.length > 0 ? (
          <div class="backref-group">
            <h3>Other packages</h3>
            <ul class="qualnames qualnames-external">
              {view.externalBackrefs.map((b) => (
                <li>
                  <span class="backref-pkg">{b.pkg}</span>
                  <a href={b.url}>{b.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ) : null}
      </section>
    ) : null
  }
</BundleLayout>
