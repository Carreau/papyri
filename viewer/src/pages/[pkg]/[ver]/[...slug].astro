---
import {
  ingestDir,
  linkForRef,
  loadModule,
  slugToQualname,
  type IngestedDoc,
  type IRNode,
  type SectionNode,
} from "../../../lib/ir-reader.ts";
import { getBackrefs, resolveRef } from "../../../lib/graph.ts";
import IrNode from "../../../components/IrNode.astro";
import Signature from "../../../components/Signature.astro";
import BundleLayout from "../../../layouts/BundleLayout.astro";
import { join } from "node:path";

export const prerender = false;

const { pkg, ver, slug } = Astro.params;

if (!pkg || !ver || slug === undefined) {
  return new Response("Not found", { status: 404 });
}

const qualname = slugToQualname(slug);
const bundlePath = join(ingestDir(), pkg, ver);

let doc: IngestedDoc;
try {
  doc = await loadModule(bundlePath, qualname);
} catch {
  return new Response(`Module ${qualname} not found`, { status: 404 });
}

// Iteration order of sections: prefer _ordered_sections, fall back to
// Object.keys. Skip sections whose Section body is empty.
const orderedKeys: string[] = doc._ordered_sections ?? [];
const contentKeys: string[] = Object.keys(doc._content ?? {});
const renderOrder: string[] = [
  ...orderedKeys.filter((k) => contentKeys.includes(k)),
  ...contentKeys.filter((k) => !orderedKeys.includes(k)),
];

interface RenderSection {
  title: string;
  section: SectionNode;
}
const sections: RenderSection[] = [];
for (const key of renderOrder) {
  const s = doc._content[key] as SectionNode | undefined;
  if (!s) continue;
  if (!Array.isArray(s.children) || s.children.length === 0) continue;
  sections.push({ title: key, section: s });
}

const arbitrary = Array.isArray(doc.arbitrary) ? doc.arbitrary : [];

// example_section_data is a Section (tag 4015) on IngestedDoc that was
// previously ignored. Render it after the regular sections if it contains
// anything. Normalise to a list of child IR nodes so the template stays flat.
const exampleSection = (() => {
  const es = doc.example_section_data as SectionNode | null | undefined;
  if (!es) return null;
  const kids = Array.isArray(es.children) ? es.children : [];
  if (kids.length === 0) return null;
  return { title: es.title ?? "Examples", children: kids };
})();

// Section children sometimes contain node types the renderer doesn't handle.
// IrNode.astro already falls back to a JSON dump per-node; we don't dump the
// whole section just because one child is unhandled.
function sectionChildren(s: SectionNode): IRNode[] {
  return Array.isArray(s.children) ? s.children : [];
}

// ---------------------------------------------------------------------------
// M2 crosslinks.
// resolveXref is handed to <IrNode> and called per CrossRef node at render time.
// It closes over the cached DB handle (openGraphDb caches) so we don't open
// the file per node. The CrossRef IR shape:
//   { __type: "CrossRef", value: label, reference: RefInfo, kind, anchor }
// where `reference` is a RefInfo tag node with fields (module, version, kind,
// path). We prefer that resolved reference, falling back to the top-level
// CrossRef.kind / value pair.
// ---------------------------------------------------------------------------
interface CrossRefShape {
  value?: string;
  reference?: {
    __type?: string;
    module?: string;
    version?: string;
    kind?: string;
    path?: string;
  } | null;
  kind?: string;
}

function resolveXref(raw: unknown): { url: string; label: string } | null {
  const n = raw as CrossRefShape | null;
  if (!n) return null;
  const label = n.value ?? "";
  const ref = n.reference;
  if (!ref || !ref.module || !ref.path || !ref.kind) return null;
  // Skip papyri's sentinel "unresolved" placeholder.
  if (ref.module === "current-module" || ref.kind === "to-resolve") return null;
  const resolved = resolveRef({
    pkg: ref.module,
    ver: ref.version ?? "?",
    kind: ref.kind,
    path: ref.path,
  });
  if (!resolved) return null;
  const url = linkForRef(resolved);
  if (!url) return null;
  return { url, label };
}

// Backrefs for this document, split into same-package and cross-package.
const backrefs = getBackrefs({ pkg, ver, kind: "module", path: qualname });
interface BackrefRow {
  url: string;
  label: string;
  key: string;
  // For external refs, include the package name as context.
  pkg?: string;
}
const internalBackrefRows: BackrefRow[] = [];
const externalBackrefRows: BackrefRow[] = [];
const _seen = new Set<string>();
for (const b of backrefs) {
  const url = linkForRef(b);
  if (!url) continue;
  const key = `${b.pkg}/${b.ver}/${b.kind}/${b.path}`;
  if (_seen.has(key)) continue;
  _seen.add(key);
  if (b.pkg === pkg) {
    internalBackrefRows.push({ url, label: b.path, key });
  } else {
    externalBackrefRows.push({ url, label: b.path, key, pkg: b.pkg });
  }
}
---

<BundleLayout
  pkg={pkg!}
  ver={ver!}
  bundlePath={bundlePath}
  title={`${qualname} — Papyri viewer`}
  activeQualname={qualname}
>
  <p class="crumb">
    <a href="/">bundles</a> / <a href={`/${pkg}/${ver}/`}>{pkg} {ver}</a>
  </p>

  <header class="qa-header">
    {doc.item_type ? <p class="kind">{doc.item_type}</p> : null}
    <h1><code>{doc.qa}</code></h1>
    {
      doc.item_file ? (
        <p class="source">
          source: <code>{doc.item_file}</code>
          {doc.item_line != null ? <Fragment>:{doc.item_line}</Fragment> : null}
        </p>
      ) : null
    }
  </header>

  {
    doc.signature ? (
      <section class="signature">
        <h2>Signature</h2>
        <Signature signature={doc.signature} />
      </section>
    ) : null
  }

  {
    sections.map(({ title, section }) => (
      <section class={`doc-section doc-section-${title.toLowerCase().replace(/\s+/g, "-")}`}>
        <h2>{title}</h2>
        {sectionChildren(section).map((c) => (
          <IrNode node={c} resolveXref={resolveXref} />
        ))}
      </section>
    ))
  }

  {
    arbitrary.length > 0 ? (
      <section class="doc-section doc-section-arbitrary">
        <h2>Additional content</h2>
        {arbitrary.map((s) => (
          <div>
            {s.title ? <h3>{s.title}</h3> : null}
            {sectionChildren(s).map((c) => (
              <IrNode node={c} resolveXref={resolveXref} />
            ))}
          </div>
        ))}
      </section>
    ) : null
  }

  {
    exampleSection ? (
      <section class="doc-section doc-section-examples">
        <h2>{exampleSection.title}</h2>
        {exampleSection.children.map((c) => (
          <IrNode node={c} resolveXref={resolveXref} />
        ))}
      </section>
    ) : null
  }

  {
    doc.aliases && doc.aliases.length > 0 ? (
      <section class="aliases">
        <h2>Aliases</h2>
        <ul>
          {doc.aliases.map((a) => (
            <li>
              <code>{a}</code>
            </li>
          ))}
        </ul>
      </section>
    ) : null
  }

  {
    internalBackrefRows.length > 0 || externalBackrefRows.length > 0 ? (
      <section class="backrefs">
        <h2>Referenced by</h2>
        {internalBackrefRows.length > 0 ? (
          <div class="backref-group">
            <h3>This package</h3>
            <ul class="qualnames">
              {internalBackrefRows.map((b) => (
                <li>
                  <a href={b.url}>{b.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ) : null}
        {externalBackrefRows.length > 0 ? (
          <div class="backref-group">
            <h3>Other packages</h3>
            <ul class="qualnames qualnames-external">
              {externalBackrefRows.map((b) => (
                <li>
                  <span class="backref-pkg">{b.pkg}</span>
                  <a href={b.url}>{b.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ) : null}
      </section>
    ) : null
  }
</BundleLayout>
