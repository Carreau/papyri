---
import {
  linkForRef,
  listIngestedBundles,
  loadCbor,
  type IngestedDoc,
  type IRNode,
  type SectionNode,
} from "../../../../lib/ir-reader.ts";
import { listDocs } from "../../../../lib/nav.ts";
import { resolveRef } from "../../../../lib/graph.ts";
import IrNode from "../../../../components/IrNode.astro";
import BundleLayout from "../../../../layouts/BundleLayout.astro";
import { join } from "node:path";

export async function getStaticPaths() {
  const bundles = await listIngestedBundles();
  const paths: Array<{
    params: { pkg: string; ver: string; doc: string };
    props: { bundlePath: string; docPath: string };
  }> = [];
  for (const b of bundles) {
    const docs = await listDocs(b.path);
    for (const d of docs) {
      paths.push({
        // `:` is the IR path separator; map to URL `/` so
        // `whatsnew:index` becomes `/docs/whatsnew/index/`.
        params: { pkg: b.pkg, ver: b.version, doc: d.split(":").join("/") },
        props: { bundlePath: b.path, docPath: d },
      });
    }
  }
  return paths;
}

const { pkg, ver } = Astro.params;
const { bundlePath, docPath } = Astro.props as {
  bundlePath: string;
  docPath: string;
};

// Doc blobs are IngestedDoc (tag 4010). The body lives in `arbitrary` as
// Section children; `_content` is typically empty for narrative docs.
const doc = (await loadCbor(join(bundlePath, "docs", docPath))) as IngestedDoc;

const sections: SectionNode[] = Array.isArray(doc.arbitrary) ? doc.arbitrary : [];

function sectionChildren(s: SectionNode): IRNode[] {
  return Array.isArray(s.children) ? s.children : [];
}

// Produce a stable HTML id from a heading string.
function slugify(title: string): string {
  return (
    title
      .toLowerCase()
      .replace(/\s+/g, "-")
      .replace(/[^a-z0-9-]/g, "")
      .replace(/^-+|-+$/g, "") || "section"
  );
}

// Section anchor: prefer the RST target label (explicit ``.. _label:``),
// fall back to the slugified title. Returns undefined when there is no title.
function sectionId(s: SectionNode): string | undefined {
  if (!s.title) return undefined;
  return s.target ?? slugify(s.title);
}

// Mirror the qualname page's resolveXref: close over the cached DB handle
// so XRefs become resolved links at render time.
interface XRefShape {
  value?: string;
  reference?: {
    module?: string;
    version?: string;
    kind?: string;
    path?: string;
  } | null;
  kind?: string;
}

function resolveXref(raw: unknown): { url: string; label: string } | null {
  const n = raw as XRefShape | null;
  if (!n) return null;
  const label = n.value ?? "";
  const ref = n.reference;
  if (!ref || !ref.module || !ref.path || !ref.kind) return null;
  if (ref.module === "current-module" || ref.kind === "to-resolve") return null;
  const resolved = resolveRef({
    pkg: ref.module,
    ver: ref.version ?? "?",
    kind: ref.kind,
    path: ref.path,
  });
  if (!resolved) return null;
  const url = linkForRef(resolved);
  if (!url) return null;
  return { url, label };
}

// Use the first section's RST title as the visible <h1>. Narrative docs
// store their document-level heading in arbitrary[0].title; falling back to
// doc.qa avoids showing raw IR keys like "config:details".
const displayTitle = sections[0]?.title || doc.qa || docPath;
const pageTitle = doc.qa || docPath;

// If the first section's title became the page <h1>, suppress its <h2>
// inside the body so the heading isn't rendered twice.
const firstTitleIsH1 = sections.length > 0 && sections[0].title === displayTitle;

// TOC: sections with titles, skipping the first when its title is the <h1>.
const tocEntries = sections.filter((s, i) => s.title && !(i === 0 && firstTitleIsH1));
---

<BundleLayout
  pkg={pkg!}
  ver={ver!}
  bundlePath={bundlePath}
  title={`${pageTitle} — ${pkg} ${ver}`}
  activeDocPath={docPath}
>
  <p class="crumb">
    <a href="/">bundles</a> / <a href={`/${pkg}/${ver}/`}>{pkg} {ver}</a> /
    <span>docs</span>
  </p>

  <header class="qa-header">
    <p class="kind">Doc</p>
    <h1>{displayTitle}</h1>
    <p class="source"><code>docs/{docPath}</code></p>
  </header>

  {
    tocEntries.length >= 2 && (
      <nav class="doc-toc" aria-label="On this page">
        <p class="doc-toc-label">On this page</p>
        <ul>
          {tocEntries.map((s) => (
            <li>
              <a href={`#${sectionId(s)}`}>{s.title}</a>
            </li>
          ))}
        </ul>
      </nav>
    )
  }

  {
    sections.length === 0 ? (
      <p class="lede">This doc is empty.</p>
    ) : (
      sections.map((s, i) => {
        const id = sectionId(s);
        const showH2 = s.title && !(i === 0 && firstTitleIsH1);
        return (
          <section class="doc-section" id={id}>
            {showH2 ? <h2>{s.title}</h2> : null}
            {sectionChildren(s).map((c) => (
              <IrNode node={c} resolveXref={resolveXref} />
            ))}
          </section>
        );
      })
    )
  }
</BundleLayout>
