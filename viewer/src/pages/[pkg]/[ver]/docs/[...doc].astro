---
import {
  loadBundleCbor,
  buildXrefResolver,
  type IngestedDoc,
  type IRNode,
  type SectionNode,
} from "../../../../lib/ir-reader.ts";
import IrNode from "../../../../components/IrNode.astro";
import BundleLayout from "../../../../layouts/BundleLayout.astro";

const { pkg, ver, doc: docParam } = Astro.params;
const docPath = decodeURIComponent(docParam ?? "");

let doc: IngestedDoc;
try {
  doc = await loadBundleCbor<IngestedDoc>(pkg!, ver!, `docs/${docPath}`);
} catch {
  return Astro.redirect("/404");
}

const sections: SectionNode[] = Array.isArray(doc.arbitrary) ? doc.arbitrary : [];

function sectionChildren(s: SectionNode): IRNode[] {
  return Array.isArray(s.children) ? s.children : [];
}

const allNodes: unknown[] = sections.flatMap(sectionChildren);
const resolveXref = await buildXrefResolver(allNodes);

const pageTitle = doc.qa || docPath;
---

<BundleLayout
  pkg={pkg!}
  ver={ver!}
  title={`${pageTitle} — ${pkg} ${ver}`}
  activeDocPath={docPath}
>
  <p class="crumb">
    <a href="/">bundles</a> / <a href={`/${pkg}/${ver}/`}>{pkg} {ver}</a> /
    <span>docs</span>
  </p>

  <header class="qa-header">
    <p class="kind">Doc</p>
    <h1>{pageTitle}</h1>
    <p class="source"><code>docs/{docPath}</code></p>
  </header>

  {
    sections.length === 0 ? (
      <p class="lede">This doc is empty.</p>
    ) : (
      sections.map((s) => (
        <section class="doc-section">
          {s.title ? <h2>{s.title}</h2> : null}
          {sectionChildren(s).map((c) => (
            <IrNode node={c} resolveXref={resolveXref} />
          ))}
        </section>
      ))
    )
  }
</BundleLayout>
