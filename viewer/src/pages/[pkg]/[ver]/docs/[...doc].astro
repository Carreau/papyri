---
import { loadCbor, sectionChildren, type IngestedDoc } from "../../../../lib/ir-reader.ts";
import { buildDocPageView } from "../../../../lib/doc-page.ts";
import { getBackends } from "../../../../lib/backends.ts";
import { buildXrefResolver } from "../../../../lib/xref.ts";
import IrNode from "../../../../components/IrNode.astro";
import BundleLayout from "../../../../layouts/BundleLayout.astro";

export const prerender = false;

const { pkg, ver, doc: docParam } = Astro.params;
if (!pkg || !ver || !docParam) {
  return new Response("Not found", { status: 404 });
}
// Reverse the URL path → IR doc path mapping (`/` → `:`).
const docPath = docParam.split("/").join(":");

const { blobStore, graphDb } = await getBackends();

let doc: IngestedDoc;
try {
  doc = (await loadCbor(blobStore, pkg, ver, "docs", docPath)) as IngestedDoc;
} catch {
  return new Response(`Doc ${docPath} not found`, { status: 404 });
}
const view = buildDocPageView(doc, docPath);
const resolveXref = await buildXrefResolver(graphDb, doc, pkg, ver);

function sectionHeading(title: string, level: number): string {
  const tag = `h${Math.min(Math.max(level + 1, 2), 6)}`;
  const safe = title.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  return `<${tag}>${safe}</${tag}>`;
}
---

<BundleLayout
  pkg={pkg}
  ver={ver}
  title={`${view.pageTitle} — ${pkg} ${ver}`}
  activeDocPath={docPath}
  hasToc={view.tocEntries.length >= 2}
>
  <p class="crumb">
    <a href="/">bundles</a> / <a href={`/${pkg}/${ver}/`}>{pkg} {ver}</a> /
    <span>docs</span>
  </p>

  <header class="qa-header">
    <p class="kind">Doc</p>
    <h1>{view.displayTitle}</h1>
    <p class="source"><code>docs/{docPath}</code></p>
  </header>

  {
    view.sections.length === 0 ? (
      <p class="lede">This doc is empty.</p>
    ) : (
      view.sections.map((s, i) => {
        const id = view.sectionIds.get(s);
        const showH2 = s.title && !(i === 0 && view.firstTitleIsH1);
        return (
          <section class="doc-section" id={id}>
            {showH2 ? <Fragment set:html={sectionHeading(s.title!, s.level ?? 0)} /> : null}
            {sectionChildren(s).map((c) => (
              <IrNode node={c} resolveXref={resolveXref} />
            ))}
          </section>
        );
      })
    )
  }

  {
    view.tocEntries.length >= 2 && (
      <Fragment slot="page-toc">
        <nav class="page-toc" aria-label="On this page">
          <p class="page-toc-label">On this page</p>
          <ul>
            {view.tocEntries.map((e) => (
              <li
                class={`page-toc-level-${Math.min(Math.max(e.level, 1), 4)}`}
                data-parent-h2={e.parentH2Id}
                data-level={e.level}
              >
                <a class="page-toc-link" href={`#${e.id}`}>
                  {e.section.title}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </Fragment>
    )
  }
</BundleLayout>

<script>
  const links = [...document.querySelectorAll<HTMLAnchorElement>(".page-toc-link")];
  const tocItems = [...document.querySelectorAll<HTMLLIElement>("nav.page-toc li[data-level]")];
  const sections = [...document.querySelectorAll<HTMLElement>("section.doc-section[id]")];

  const sectionParentH2: string[] = [];
  {
    let currentH2 = sections[0]?.id ?? "";
    for (const s of sections) {
      const h2 = s.querySelector("h2");
      if (h2) currentH2 = s.id;
      sectionParentH2.push(currentH2);
    }
  }

  if (links.length > 0 && sections.length > 0) {
    function updateActive(): void {
      const threshold = window.scrollY + window.innerHeight * 0.25;
      let activeIdx = 0;
      for (let i = 0; i < sections.length; i++) {
        if (sections[i].offsetTop <= threshold) activeIdx = i;
        else break;
      }
      const activeId = sections[activeIdx].id;
      const activeH2 = sectionParentH2[activeIdx];

      for (const link of links) {
        link.classList.toggle("is-active", link.getAttribute("href") === "#" + activeId);
      }
      for (const li of tocItems) {
        const level = Number(li.dataset.level ?? "1");
        if (level <= 1) continue;
        const hidden = li.dataset.parentH2 !== activeH2;
        li.classList.toggle("is-collapsed", hidden);
      }
    }
    window.addEventListener("scroll", updateActive, { passive: true });
    updateActive();
  }
</script>
