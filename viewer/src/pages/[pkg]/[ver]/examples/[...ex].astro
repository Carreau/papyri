---
import {
  loadBundleCbor,
  buildXrefResolver,
  type IRNode,
  type SectionNode,
} from "../../../../lib/ir-reader.ts";
import IrNode from "../../../../components/IrNode.astro";
import BundleLayout from "../../../../layouts/BundleLayout.astro";

const { pkg, ver, ex } = Astro.params;
const examplePath = decodeURIComponent(ex ?? "");

let section: SectionNode;
try {
  section = await loadBundleCbor<SectionNode>(pkg!, ver!, `examples/${examplePath}`);
} catch {
  return Astro.redirect("/404");
}

const children: IRNode[] = Array.isArray(section.children) ? section.children : [];
const resolveXref = await buildXrefResolver(children);
---

<BundleLayout
  pkg={pkg!}
  ver={ver!}
  title={`${examplePath} — ${pkg} ${ver}`}
  activeExamplePath={examplePath}
>
  <p class="crumb">
    <a href="/">bundles</a> / <a href={`/${pkg}/${ver}/`}>{pkg} {ver}</a> /
    <span>examples</span>
  </p>

  <header class="qa-header">
    <p class="kind">Example</p>
    <h1>{examplePath}</h1>
  </header>

  {
    children.length === 0 ? (
      <p class="lede">This example is empty.</p>
    ) : (
      <section class="doc-section">
        {children.map((c) => (
          <IrNode node={c} resolveXref={resolveXref} />
        ))}
      </section>
    )
  }
</BundleLayout>
