---
import BundleLayout from "../../../../layouts/BundleLayout.astro";
import { collectBundleImages } from "../../../../lib/image-index.ts";
import { getBackends } from "../../../../lib/backends.ts";

export const prerender = false;

const { pkg, ver } = Astro.params;
if (!pkg || !ver) return new Response(null, { status: 404 });

const { blobStore } = await getBackends();
const entries = await collectBundleImages(blobStore, pkg, ver);
---

<BundleLayout pkg={pkg} ver={ver} title={`Images — ${pkg} ${ver} — Papyri viewer`}>
  <p class="crumb"><a href={`/${pkg}/${ver}/`}>&larr; {pkg} {ver}</a></p>
  <h1>Images</h1>
  <p class="lede">
    {entries.length} image{entries.length !== 1 ? "s" : ""}
  </p>

  {
    entries.length === 0 ? (
      <p class="no-images">No images in this bundle.</p>
    ) : (
      <div class="image-gallery">
        {entries.map((entry) => (
          <div class="image-card">
            <a
              class="image-thumb-link"
              href={entry.img.src}
              target="_blank"
              rel="noopener noreferrer"
            >
              <img
                class="image-thumb"
                src={entry.img.src}
                alt={entry.img.kind === "Image" ? entry.img.alt : entry.img.assetPath}
                loading="lazy"
              />
            </a>
            <div class="image-meta">
              <code class="image-filename">
                {entry.img.kind === "Figure" ? entry.img.assetPath : entry.img.src}
              </code>
              {entry.pages.length > 0 ? (
                <details class="image-refs">
                  <summary>
                    Used on {entry.pages.length} page
                    {entry.pages.length !== 1 ? "s" : ""}
                  </summary>
                  <ul>
                    {entry.pages.map((p) => (
                      <li>
                        <a href={p.href}>{p.label}</a>
                      </li>
                    ))}
                  </ul>
                </details>
              ) : (
                <span class="image-no-refs">Not referenced</span>
              )}
            </div>
          </div>
        ))}
      </div>
    )
  }
</BundleLayout>

<style>
  .no-images {
    color: var(--fg-muted);
    margin-top: 1rem;
  }
  .image-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-top: 1.5rem;
  }
  .image-card {
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--surface);
    display: flex;
    flex-direction: column;
  }
  .image-thumb-link {
    display: block;
    background: var(--surface-alt);
  }
  .image-thumb {
    width: 100%;
    height: 160px;
    object-fit: contain;
    display: block;
  }
  .image-meta {
    padding: 0.6rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }
  .image-filename {
    font-size: 0.78rem;
    word-break: break-all;
    color: var(--fg-muted);
  }
  .image-refs summary {
    cursor: pointer;
    font-size: 0.82rem;
    color: var(--accent);
  }
  .image-refs ul {
    margin: 0.3rem 0 0 1rem;
    padding: 0;
    list-style: disc;
    font-size: 0.82rem;
  }
  .image-refs li {
    margin: 0.15rem 0;
  }
  .image-no-refs {
    font-size: 0.82rem;
    color: var(--fg-muted);
    font-style: italic;
  }
</style>
