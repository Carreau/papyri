---
import { listModules } from "../../../lib/ir-reader.ts";
import BundleLayout from "../../../layouts/BundleLayout.astro";

const { pkg, ver } = Astro.params;
const qualnames = await listModules(pkg!, ver!);
---

<BundleLayout
  pkg={pkg!}
  ver={ver!}
  title={`${pkg} ${ver} — Papyri viewer`}
>
  <p class="crumb"><a href="/">&larr; bundles</a></p>
  <h1>
    {pkg} <span class="version">{ver}</span>
  </h1>
  <p class="lede">{qualnames.length} qualnames</p>
</BundleLayout>
