---
import {
  listIngestedBundles,
  listModules,
  qualnameToSlug,
} from "../../../lib/ir-reader.ts";
import "../../../styles/global.css";

export async function getStaticPaths() {
  const bundles = await listIngestedBundles();
  return bundles.map((b) => ({
    params: { pkg: b.pkg, ver: b.version },
    props: { bundlePath: b.path },
  }));
}

const { pkg, ver } = Astro.params;
const { bundlePath } = Astro.props as { bundlePath: string };
const qualnames = await listModules(bundlePath);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pkg} {ver} — Papyri viewer</title>
  </head>
  <body>
    <main>
      <p class="crumb"><a href="/">&larr; bundles</a></p>
      <h1>
        {pkg} <span class="version">{ver}</span>
      </h1>
      <p class="lede">{qualnames.length} qualnames</p>

      <ul class="qualnames">
        {
          qualnames.map((qa) => (
            <li>
              <a href={`/${pkg}/${ver}/${qualnameToSlug(qa)}/`}>{qa}</a>
            </li>
          ))
        }
      </ul>
    </main>
  </body>
</html>
