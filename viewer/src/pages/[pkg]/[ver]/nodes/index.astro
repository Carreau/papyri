---
import { join } from "node:path";
import BundleLayout from "../../../../layouts/BundleLayout.astro";
import IrNode from "../../../../components/IrNode.astro";
import NodeTypeFilter from "../../../../components/NodeTypeFilter.tsx";
import {
  listIngestedBundles,
  listModules,
  loadModule,
  loadCbor,
  collectNodes,
  ALL_NODE_TYPES,
  type IRNode,
} from "../../../../lib/ir-reader.ts";
import { listDocs, listExamples } from "../../../../lib/nav.ts";
import { NODE_CONFIGS } from "../../../../lib/node-configs.ts";

export async function getStaticPaths() {
  const bundles = await listIngestedBundles();
  return bundles.map((b) => ({
    params: { pkg: b.pkg, ver: b.version },
    props: { bundlePath: b.path },
  }));
}

const { pkg, ver } = Astro.params;
const { bundlePath } = Astro.props as { bundlePath: string };

// Collect every known IR node type across the bundle.
const allTypes: ReadonlySet<string> = ALL_NODE_TYPES;
const DISPLAY_LIMIT = 1000;

interface PageRef {
  label: string;
  href: string;
}

interface NodeEntry {
  node: IRNode;
  value: string;
  pages: PageRef[];
}

// Key: "<type>|<displayValue>" so same text under different types stays separate.
const valueMap = new Map<string, NodeEntry>();

function entryKey(type: string, val: string): string {
  return `${type}\0${val}`;
}

function displayValue(n: IRNode): string | null {
  // Delegate to the matching config's displayValue, fallback to JSON.
  for (const cfg of Object.values(NODE_CONFIGS)) {
    if (cfg.types.has((n as any).__type)) return cfg.displayValue(n);
  }
  return JSON.stringify(n).slice(0, 120);
}

function addHits(nodes: IRNode[], page: PageRef) {
  for (const n of nodes) {
    const val = displayValue(n);
    if (val === null) continue;
    const k = entryKey((n as any).__type, val);
    const existing = valueMap.get(k);
    if (existing) {
      if (!existing.pages.some((p) => p.href === page.href)) {
        existing.pages.push(page);
      }
    } else {
      valueMap.set(k, { node: n, value: val, pages: [page] });
    }
  }
}

// Walk modules
const qualnames = await listModules(bundlePath);
await Promise.all(
  qualnames.map(async (qa) => {
    let doc;
    try {
      doc = await loadModule(bundlePath, qa);
    } catch {
      return;
    }
    addHits(collectNodes(doc, allTypes), {
      label: qa,
      href: `/${pkg}/${ver}/${qa.replace(/:/g, "$")}/`,
    });
  })
);

// Walk narrative docs
const docPaths = await listDocs(bundlePath);
await Promise.all(
  docPaths.map(async (docPath) => {
    let section;
    try {
      section = await loadCbor(join(bundlePath, "docs", docPath));
    } catch {
      return;
    }
    addHits(collectNodes(section, allTypes), {
      label: docPath,
      href: `/${pkg}/${ver}/docs/${docPath.split("/").map(encodeURIComponent).join("/")}/`,
    });
  })
);

// Walk examples
const exPaths = await listExamples(bundlePath);
await Promise.all(
  exPaths.map(async (exPath) => {
    let section;
    try {
      section = await loadCbor(join(bundlePath, "examples", exPath));
    } catch {
      return;
    }
    addHits(collectNodes(section, allTypes), {
      label: exPath,
      href: `/${pkg}/${ver}/examples/${exPath.split("/").map(encodeURIComponent).join("/")}/`,
    });
  })
);

// Sort: group by type, then by value length within each type.
const allEntries = [...valueMap.values()].sort((a, b) => {
  const ta = (a.node as any).__type as string;
  const tb = (b.node as any).__type as string;
  if (ta !== tb) return ta.localeCompare(tb);
  return a.value.length - b.value.length || a.value.localeCompare(b.value);
});
const truncated = allEntries.length > DISPLAY_LIMIT;
const entries = truncated ? allEntries.slice(0, DISPLAY_LIMIT) : allEntries;

// Build per-type counts for the filter panel (based on shown entries).
const typeCounts = [...allTypes]
  .sort()
  .map((key) => ({
    key,
    label: key,
    count: entries.filter((e) => (e.node as any).__type === key).length,
  }))
  .filter((t) => t.count > 0);
---

<BundleLayout
  pkg={pkg!}
  ver={ver!}
  bundlePath={bundlePath}
  title={`All nodes — ${pkg} ${ver} — Papyri viewer`}
>
  <p class="crumb"><a href={`/${pkg}/${ver}/`}>&larr; {pkg} {ver}</a></p>
  <h1>All nodes</h1>
  <p class="lede">
    {truncated ? (
      <>Showing {DISPLAY_LIMIT} of {allEntries.length} unique values across {typeCounts.length} node type{typeCounts.length !== 1 ? "s" : ""}. Use the type filter to narrow results.</>
    ) : (
      <>{entries.length} unique value{entries.length !== 1 ? "s" : ""} across {typeCounts.length} node type{typeCounts.length !== 1 ? "s" : ""}</>
    )}
  </p>

  <NodeTypeFilter client:load listId="node-list" types={typeCounts} defaultChecked={false} />

  {
    entries.length === 0 ? (
      <p class="no-nodes">No nodes found in this bundle.</p>
    ) : (
      <dl id="node-list" class="node-list">
        {entries.map((entry) => (
          <div class="node-entry" data-nodetype={(entry.node as any).__type}>
            <dt>
              <span class="node-kind">{(entry.node as any).__type}</span>
              <div class="node-value">
                <IrNode node={entry.node} />
              </div>
            </dt>
            <dd>
              <details class="node-refs">
                <summary>
                  {entry.pages.length} page{entry.pages.length !== 1 ? "s" : ""}
                </summary>
                <ul>
                  {entry.pages.map((p) => (
                    <li>
                      <a href={p.href}>{p.label}</a>
                    </li>
                  ))}
                </ul>
              </details>
            </dd>
          </div>
        ))}
      </dl>
    )
  }
</BundleLayout>

<style>
  .no-nodes {
    color: var(--fg-muted);
    margin-top: 1rem;
  }
  .node-list {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .node-entry {
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--surface);
  }
  .node-entry dt {
    background: var(--surface-alt);
    padding: 0.5rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .node-kind {
    font-size: 0.72rem;
    font-family: var(--mono);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .node-value {
    max-height: 12rem;
    overflow: auto;
  }
  .node-entry dd {
    margin: 0;
    padding: 0.5rem 0.75rem;
  }
  .node-refs summary {
    cursor: pointer;
    font-size: 0.82rem;
    color: var(--accent);
  }
  .node-refs ul {
    margin: 0.3rem 0 0 1rem;
    padding: 0;
    list-style: disc;
    font-size: 0.82rem;
  }
  .node-refs li {
    margin: 0.15rem 0;
  }
</style>
