---
// Per-package qualname diff between two ingested versions.
// Query params: ?from=<ver>&to=<ver>
//
// Three buckets:
//   added   — qualnames present in `to` but not in `from`
//   removed — qualnames present in `from` but not in `to`
//   changed — qualnames in both, but with a different blob digest
// "kept" is the count of qualnames whose digest is identical across versions.
//
// Digests come from the graph store (`nodes.digest` — a 16-byte BLAKE2b
// of the raw CBOR blob bytes, set by the ingester at write time).
import { listIngestedPackages } from "../../lib/ir-reader.ts";
import { listDigests } from "../../lib/graph.ts";
import { getBackends } from "../../lib/backends.ts";
import { linkForQualname } from "../../lib/links.ts";
import BaseLayout from "../../layouts/BaseLayout.astro";

export const prerender = false;

const { pkg } = Astro.params;
if (!pkg) return new Response("Not found", { status: 404 });

const url = new URL(Astro.request.url);
const fromVer = url.searchParams.get("from");
const toVer = url.searchParams.get("to");

const { blobStore, graphDb } = await getBackends();
const entry = (await listIngestedPackages(blobStore)).find((p) => p.pkg === pkg);
if (!entry) return new Response(`Package ${pkg} not found`, { status: 404 });

const valid = (v: string | null) => !!v && entry.versions.includes(v);
const haveBoth = valid(fromVer) && valid(toVer);

let added: string[] = [];
let removed: string[] = [];
let changed: string[] = [];
let kept = 0;

if (haveBoth && fromVer && toVer) {
  const [fromDigests, toDigests] = await Promise.all([
    listDigests(graphDb, pkg, fromVer, "module"),
    listDigests(graphDb, pkg, toVer, "module"),
  ]);
  const fromKeys = [...fromDigests.keys()];
  const toKeys = [...toDigests.keys()];
  const fromSet = new Set(fromKeys);
  const toSet = new Set(toKeys);
  added = toKeys.filter((q) => !fromSet.has(q)).sort();
  removed = fromKeys.filter((q) => !toSet.has(q)).sort();
  for (const q of toKeys) {
    if (!fromSet.has(q)) continue;
    if (fromDigests.get(q) !== toDigests.get(q)) changed.push(q);
    else kept++;
  }
  changed.sort();
}
---

<BaseLayout title={`${pkg} diff — Papyri viewer`}>
  <p class="crumb">
    <a href={`/${pkg}/`}>&larr; {pkg}</a>
  </p>
  <h1>
    {pkg}
    <span class="muted">diff</span>
  </h1>

  <form method="get" class="diff-picker">
    <label>
      From
      <select name="from">
        {
          entry.versions.map((v) => (
            <option value={v} selected={v === fromVer}>
              {v}
            </option>
          ))
        }
      </select>
    </label>
    <label>
      To
      <select name="to">
        {
          entry.versions.map((v) => (
            <option value={v} selected={v === toVer}>
              {v}
            </option>
          ))
        }
      </select>
    </label>
    <button type="submit">Compare</button>
  </form>

  {
    !haveBoth ? (
      <p class="empty">
        Pick two ingested versions of <code>{pkg}</code> to compare.
      </p>
    ) : (
      <>
        <p class="lede">
          <code>{fromVer}</code> → <code>{toVer}</code>: <strong>{added.length}</strong> added,{" "}
          <strong>{removed.length}</strong> removed, <strong>{changed.length}</strong> changed,{" "}
          {kept} unchanged.
        </p>

        <div class="diff-grid">
          <section>
            <h2 class="added">Added in {toVer}</h2>
            {added.length === 0 ? (
              <p class="muted">none</p>
            ) : (
              <ul>
                {added.map((q) => (
                  <li>
                    <a href={linkForQualname(pkg, toVer!, q)}>{q}</a>
                  </li>
                ))}
              </ul>
            )}
          </section>
          <section>
            <h2 class="removed">Removed since {fromVer}</h2>
            {removed.length === 0 ? (
              <p class="muted">none</p>
            ) : (
              <ul>
                {removed.map((q) => (
                  <li>
                    <a href={linkForQualname(pkg, fromVer!, q)}>{q}</a>
                  </li>
                ))}
              </ul>
            )}
          </section>
          <section class="diff-changed">
            <h2 class="changed">Changed</h2>
            {changed.length === 0 ? (
              <p class="muted">none</p>
            ) : (
              <ul>
                {changed.map((q) => (
                  <li>
                    <a href={linkForQualname(pkg, toVer!, q)}>{q}</a>
                    <span class="changed-from">
                      (was <a href={linkForQualname(pkg, fromVer!, q)}>{fromVer}</a>)
                    </span>
                  </li>
                ))}
              </ul>
            )}
          </section>
        </div>
      </>
    )
  }
</BaseLayout>

<style>
  .muted {
    color: var(--muted, #888);
    font-weight: normal;
  }
  .diff-picker {
    display: flex;
    gap: 1rem;
    align-items: end;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .diff-picker label {
    display: flex;
    flex-direction: column;
    font-size: 0.85rem;
  }
  .diff-picker select {
    margin-top: 0.25rem;
    padding: 0.3rem 0.5rem;
  }
  .diff-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .diff-grid .diff-changed {
    grid-column: 1 / -1;
  }
  @media (max-width: 720px) {
    .diff-grid {
      grid-template-columns: 1fr;
    }
    .diff-grid .diff-changed {
      grid-column: auto;
    }
  }
  .diff-grid h2.added {
    color: #1a7f37;
  }
  .diff-grid h2.removed {
    color: #b42318;
  }
  .diff-grid h2.changed {
    color: #9a6700;
  }
  .diff-grid ul {
    padding-left: 1.2rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.85rem;
  }
  .changed-from {
    margin-left: 0.5rem;
    color: var(--muted, #888);
    font-size: 0.8rem;
  }
</style>
