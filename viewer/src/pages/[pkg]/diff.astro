---
// Per-package content diff between two ingested versions.
// Query params: ?from=<ver>&to=<ver>
//
// Reports one block per category — API (modules), narrative docs, and
// examples. Each block has three buckets:
//   added   — identifiers present in `to` but not in `from`
//   removed — identifiers present in `from` but not in `to`
//   changed — identifiers in both, but with a different content digest
//
// Digests come from the graph store (`nodes.digest` — a 16-byte BLAKE2b
// over the IR bytes, written by the ingester. Volatile fields like
// `IngestedDoc.item_line` are stripped before hashing, so a rebuild that
// only shifts source line numbers does NOT show as "changed").
import { listIngestedPackages } from "../../lib/ir-reader.ts";
import { listDigests } from "../../lib/graph.ts";
import { getBackends } from "../../lib/backends.ts";
import { linkForDoc, linkForExample, linkForQualname } from "../../lib/links.ts";
import BaseLayout from "../../layouts/BaseLayout.astro";

export const prerender = false;

const { pkg } = Astro.params;
if (!pkg) return new Response("Not found", { status: 404 });

const url = new URL(Astro.request.url);
const fromVer = url.searchParams.get("from");
const toVer = url.searchParams.get("to");

const { blobStore, graphDb } = await getBackends();
const entry = (await listIngestedPackages(blobStore)).find((p) => p.pkg === pkg);
if (!entry) return new Response(`Package ${pkg} not found`, { status: 404 });

const valid = (v: string | null) => !!v && entry.versions.includes(v);
const haveBoth = valid(fromVer) && valid(toVer);

interface Bucket {
  added: string[];
  removed: string[];
  changed: string[];
  kept: number;
}

interface CategoryDiff {
  label: string;
  category: string;
  bucket: Bucket;
  link: (id: string, ver: string) => string;
}

function diffMaps(from: Map<string, string>, to: Map<string, string>): Bucket {
  const fromKeys = [...from.keys()];
  const toKeys = [...to.keys()];
  const fromSet = new Set(fromKeys);
  const toSet = new Set(toKeys);
  const added = toKeys.filter((q) => !fromSet.has(q)).sort();
  const removed = fromKeys.filter((q) => !toSet.has(q)).sort();
  const changed: string[] = [];
  let kept = 0;
  for (const q of toKeys) {
    if (!fromSet.has(q)) continue;
    if (from.get(q) !== to.get(q)) changed.push(q);
    else kept++;
  }
  changed.sort();
  return { added, removed, changed, kept };
}

const categorySpecs: Array<{
  label: string;
  category: string;
  link: (id: string, ver: string) => string;
}> = [
  { label: "API", category: "module", link: (id, v) => linkForQualname(pkg, v, id) },
  { label: "Docs", category: "docs", link: (id, v) => linkForDoc(pkg, v, id) },
  { label: "Examples", category: "examples", link: (id, v) => linkForExample(pkg, v, id) },
];

let totals = { added: 0, removed: 0, changed: 0, kept: 0 };
let categories: CategoryDiff[] = [];

if (haveBoth && fromVer && toVer) {
  const pairs = await Promise.all(
    categorySpecs.flatMap((s) => [
      listDigests(graphDb, pkg, fromVer, s.category),
      listDigests(graphDb, pkg, toVer, s.category),
    ])
  );
  categories = categorySpecs.map((s, i) => {
    const fromMap = pairs[i * 2]!;
    const toMap = pairs[i * 2 + 1]!;
    const bucket = diffMaps(fromMap, toMap);
    totals.added += bucket.added.length;
    totals.removed += bucket.removed.length;
    totals.changed += bucket.changed.length;
    totals.kept += bucket.kept;
    return { label: s.label, category: s.category, bucket, link: s.link };
  });
}
---

<BaseLayout title={`${pkg} diff — Papyri viewer`}>
  <p class="crumb">
    <a href={`/${pkg}/`}>&larr; {pkg}</a>
  </p>
  <h1>
    {pkg}
    <span class="muted">diff</span>
  </h1>

  <form method="get" class="diff-picker">
    <label>
      From
      <select name="from">
        {
          entry.versions.map((v) => (
            <option value={v} selected={v === fromVer}>
              {v}
            </option>
          ))
        }
      </select>
    </label>
    <label>
      To
      <select name="to">
        {
          entry.versions.map((v) => (
            <option value={v} selected={v === toVer}>
              {v}
            </option>
          ))
        }
      </select>
    </label>
    <button type="submit">Compare</button>
  </form>

  {
    !haveBoth ? (
      <p class="empty">
        Pick two ingested versions of <code>{pkg}</code> to compare.
      </p>
    ) : (
      <>
        <p class="lede">
          <code>{fromVer}</code> → <code>{toVer}</code>: <strong>{totals.added}</strong> added,{" "}
          <strong>{totals.removed}</strong> removed, <strong>{totals.changed}</strong> changed,{" "}
          {totals.kept} unchanged.
        </p>

        {categories.map((c) => {
          const empty =
            c.bucket.added.length === 0 &&
            c.bucket.removed.length === 0 &&
            c.bucket.changed.length === 0 &&
            c.bucket.kept === 0;
          if (empty) return null;
          return (
            <section class="diff-category">
              <h2>
                {c.label}
                <span class="muted">
                  {" "}
                  · {c.bucket.added.length} added, {c.bucket.removed.length} removed,{" "}
                  {c.bucket.changed.length} changed, {c.bucket.kept} unchanged
                </span>
              </h2>
              <div class="diff-grid">
                <section>
                  <h3 class="added">Added in {toVer}</h3>
                  {c.bucket.added.length === 0 ? (
                    <p class="muted">none</p>
                  ) : (
                    <ul>
                      {c.bucket.added.map((id) => (
                        <li>
                          <a href={c.link(id, toVer!)}>{id}</a>
                        </li>
                      ))}
                    </ul>
                  )}
                </section>
                <section>
                  <h3 class="removed">Removed since {fromVer}</h3>
                  {c.bucket.removed.length === 0 ? (
                    <p class="muted">none</p>
                  ) : (
                    <ul>
                      {c.bucket.removed.map((id) => (
                        <li>
                          <a href={c.link(id, fromVer!)}>{id}</a>
                        </li>
                      ))}
                    </ul>
                  )}
                </section>
                <section class="diff-changed">
                  <h3 class="changed">Changed</h3>
                  {c.bucket.changed.length === 0 ? (
                    <p class="muted">none</p>
                  ) : (
                    <ul>
                      {c.bucket.changed.map((id) => (
                        <li>
                          <a href={c.link(id, toVer!)}>{id}</a>
                          <span class="changed-from">
                            (was <a href={c.link(id, fromVer!)}>{fromVer}</a>)
                          </span>
                        </li>
                      ))}
                    </ul>
                  )}
                </section>
              </div>
            </section>
          );
        })}
      </>
    )
  }
</BaseLayout>

<style>
  .muted {
    color: var(--muted, #888);
    font-weight: normal;
  }
  .diff-picker {
    display: flex;
    gap: 1rem;
    align-items: end;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .diff-picker label {
    display: flex;
    flex-direction: column;
    font-size: 0.85rem;
  }
  .diff-picker select {
    margin-top: 0.25rem;
    padding: 0.3rem 0.5rem;
  }
  .diff-category {
    margin-top: 2rem;
  }
  .diff-category > h2 {
    margin-bottom: 0.75rem;
  }
  .diff-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .diff-grid .diff-changed {
    grid-column: 1 / -1;
  }
  @media (max-width: 720px) {
    .diff-grid {
      grid-template-columns: 1fr;
    }
    .diff-grid .diff-changed {
      grid-column: auto;
    }
  }
  .diff-grid h2.added {
    color: #1a7f37;
  }
  .diff-grid h2.removed {
    color: #b42318;
  }
  .diff-grid h2.changed {
    color: #9a6700;
  }
  .diff-grid ul {
    padding-left: 1.2rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.85rem;
  }
  .changed-from {
    margin-left: 0.5rem;
    color: var(--muted, #888);
    font-size: 0.8rem;
  }
</style>
