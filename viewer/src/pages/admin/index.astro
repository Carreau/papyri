    border-color: var(--color-accent, #2563eb);
  }

  :global(.reingest-bundle-header) {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 0.9rem;
  }

  :global(.reingest-bundle-name) {
    font-weight: 600;
  }

  :global(.reingest-bundle-ver) {
    font-weight: 400;
    color: var(--color-muted, #666);
    font-size: 0.85em;
  }

  :global(.reingest-bundle-status) {
    font-size: 0.8rem;
    color: var(--color-muted, #666);
  }

  :global(.reingest-bundle--done .reingest-bundle-status) {
    color: var(--color-success, #16a34a);
    font-weight: 600;
  }

  :global(.reingest-bundle--warning .reingest-bundle-status) {
    color: var(--color-warn, #b45309);
    font-weight: 600;
  }

  :global(.reingest-bar-wrap) {
    margin-top: 0.4rem;
    height: 6px;
    background: var(--color-border, #e5e7eb);
    border-radius: 3px;
    overflow: hidden;
  }

  :global(.reingest-bar-fill) {
    height: 100%;
    background: var(--color-accent, #2563eb);
    border-radius: 3px;
