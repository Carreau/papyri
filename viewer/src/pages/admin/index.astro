    color: #fff;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
  }

  :global(.ext-inv-btn:disabled),
  :global(.ext-inv-reload:disabled) {
    opacity: 0.5;
    cursor: not-allowed;
  }

  :global(.ext-inv-result) {
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    font-size: 0.85rem;
  }

  :global(.ext-inv-result--ok) {
    background: var(--color-success-bg, #f0fdf4);
    border: 1px solid var(--color-success-border, #86efac);
    color: var(--color-success, #16a34a);
  }

  :global(.ext-inv-result--error) {
    background: var(--color-error-bg, #fef2f2);
    border: 1px solid var(--color-error-border, #fca5a5);
    color: var(--color-error, #dc2626);
  }

