---
// Admin panel: re-ingest raw archived bundles with live progress.
import { getBackends } from "../../lib/backends.ts";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReingestPanel from "../../components/ReingestPanel.tsx";
import ClearGraphstoreButton from "../../components/ClearGraphstoreButton.tsx";
import DropRawBundlesButton from "../../components/DropRawBundlesButton.tsx";
import ExternalInventoryPanel, {
  type ExternalProject,
} from "../../components/ExternalInventoryPanel.tsx";
import UserManagementPanel from "../../components/UserManagementPanel.tsx";
import { getAuthDb } from "../../lib/auth-db.ts";

export const prerender = false;

const { rawStore, graphDb } = await getBackends();
const rawEntries = await rawStore.list();

const users = (await getAuthDb()).listUsers();

const tableNames = ["nodes", "links", "bundles"] as const;
const tableStats: Array<{ name: string; rows: number }> = [];
for (const name of tableNames) {
  const row = await graphDb.get<{ n: number }>(`SELECT COUNT(*) AS n FROM ${name}`);
  tableStats.push({ name, rows: row?.n ?? 0 });
}

const externalProjects = await graphDb.all<ExternalProject>(
  "SELECT p.name, p.base_url, p.version, p.fetched_at, COUNT(o.name) AS objects " +
    "FROM external_projects p LEFT JOIN external_objects o ON o.project = p.name " +
    "GROUP BY p.name, p.base_url, p.version, p.fetched_at ORDER BY p.name"
);

// --- External inventory explorer (debug) ---
// Server-rendered: plain GET forms drive parameterised queries so the page
// works without a client island or extra endpoint.
interface ExtObjRow {
  project: string;
  name: string;
  domain: string;
  role: string;
  priority: number;
  uri: string;
}

const objQ = (Astro.url.searchParams.get("obj_q") ?? "").trim();
const objProject = (Astro.url.searchParams.get("obj_project") ?? "").trim();
const probeModule = (Astro.url.searchParams.get("probe_module") ?? "").trim();
const probePath = (Astro.url.searchParams.get("probe_path") ?? "").trim();

const OBJ_LIMIT = 100;
let objResults: ExtObjRow[] = [];
let objTruncated = false;
if (objQ) {
  const where = ["name LIKE ?"];
  const params: unknown[] = [`%${objQ}%`];
  if (objProject) {
    where.push("project = ?");
    params.push(objProject);
  }
  objResults = await graphDb.all<ExtObjRow>(
    `SELECT project, name, domain, role, priority, uri FROM external_objects ` +
      `WHERE ${where.join(" AND ")} ORDER BY name, project LIMIT ${OBJ_LIMIT + 1}`,
    params
  );
  objTruncated = objResults.length > OBJ_LIMIT;
  if (objTruncated) objResults = objResults.slice(0, OBJ_LIMIT);
}

// Resolve probe — mirrors resolveExternalRefs() in lib/graph.ts exactly so it
// reports what the renderer would actually do, including the `:` → `.`
// normalisation and the project-name-as-module-preference tie-break.
let probeName: string | null = null;
let probeWinner: ExtObjRow | null = null;
let probeAll: ExtObjRow[] = [];
if (probePath) {
  probeName = probePath.replace(/:/g, ".");
  probeWinner =
    (await graphDb.get<ExtObjRow>(
      "SELECT project, name, domain, role, priority, uri FROM external_objects WHERE name=? " +
        "ORDER BY (project=?) DESC, (domain='py') DESC, (priority>=0) DESC, priority ASC LIMIT 1",
      [probeName, probeModule]
    )) ?? null;
  probeAll = await graphDb.all<ExtObjRow>(
    "SELECT project, name, domain, role, priority, uri FROM external_objects WHERE name=? ORDER BY project",
    [probeName]
  );
}
---

<BaseLayout title="Admin — Papyri">
  <div class="admin-page">
    <h1>Admin</h1>

    <section class="admin-section">
      <h2>Deployment <span class="admin-debug-tag">debug</span></h2>
      <table class="admin-stats-table admin-deploy-table">
        <tbody>
          <tr>
            <td>PAPYRI_SITE</td>
            <td><code>{Astro.site?.href ?? <em class="admin-unset">(not set)</em>}</code></td>
          </tr>
          <tr>
            <td>Request origin</td>
            <td><code>{Astro.url.origin}</code></td>
          </tr>
          <tr>
            <td>Adapter</td>
            <td><code>{import.meta.env.PAPYRI_BUILD_ADAPTER}</code></td>
          </tr>
          <tr>
            <td>Build commit</td>
            <td>
              <code class="admin-commit">{import.meta.env.PAPYRI_BUILD_COMMIT}</code>
            </td>
          </tr>
        </tbody>
      </table>
    </section>

    <section class="admin-section">
      <h2>Raw archive</h2>
      {
        rawEntries.length === 0 ? (
          <p class="admin-empty">
            No bundles in the raw archive yet. Upload a bundle with <code>papyri upload</code>{" "}
            first.
          </p>
        ) : (
          <p class="admin-archive-count">
            {rawEntries.length} bundle{rawEntries.length !== 1 ? "s" : ""} archived.
          </p>
        )
      }
      <DropRawBundlesButton client:load rawCount={rawEntries.length} />
    </section>

    <section class="admin-section">
      <h2>Graph database</h2>
      <table class="admin-stats-table">
        <thead>
          <tr>
            <th>Table</th>
            <th>Rows</th>
          </tr>
        </thead>
        <tbody>
          {
            tableStats.map((t) => (
              <tr>
                <td>
                  <code>{t.name}</code>
                </td>
                <td>{t.rows.toLocaleString()}</td>
              </tr>
            ))
          }
          <tr class="admin-stats-total">
            <td>
              <strong>{tableStats.length} table{tableStats.length !== 1 ? "s" : ""}</strong>
            </td>
            <td>
              <strong>
                {tableStats.reduce((sum, t) => sum + t.rows, 0).toLocaleString()} total
              </strong>
            </td>
          </tr>
        </tbody>
      </table>
      <ClearGraphstoreButton client:load rawCount={rawEntries.length} />
    </section>

    <section class="admin-section">
      <h2>Users</h2>
      <UserManagementPanel client:load initial={users} />
    </section>

    <section class="admin-section">
      <h2>External inventories</h2>
      <ExternalInventoryPanel client:load initial={externalProjects} />
    </section>

    <section class="admin-section">
      <h2>External inventory explorer <span class="admin-debug-tag">debug</span></h2>
      <p class="ext-dbg-desc">
        Inspect the parsed intersphinx tables and test how a cross-package reference resolves. The
        probe mirrors the render-time resolver in <code>resolveExternalRefs()</code> exactly — including
        the <code>:</code>→<code>.</code> name normalisation and the project-name-as-module tie-break.
      </p>

      <h3>Resolve probe</h3>
      <form class="ext-dbg-form" method="get">
        <label>
          Top-level module (<code>RefInfo.module</code>)
          <input type="text" name="probe_module" value={probeModule} placeholder="collections" />
        </label>
        <label>
          Path (<code>RefInfo.path</code>, colon form)
          <input
            type="text"
            name="probe_path"
            value={probePath}
            placeholder="collections.abc:Mapping"
          />
        </label>
        <input type="hidden" name="obj_q" value={objQ} />
        <input type="hidden" name="obj_project" value={objProject} />
        <button class="ext-inv-btn" type="submit">Resolve</button>
      </form>
      {
        probePath && (
          <div class="ext-dbg-probe">
            <p>
              Normalised name: <code>{probeName}</code> · module preference:{" "}
              <code>{probeModule || "—"}</code>
            </p>
            {probeWinner ? (
              <p class="ext-dbg-hit">
                ✓ resolves via project <code>{probeWinner.project}</code> →{" "}
                <a class="ext-inv-url" href={probeWinner.uri}>
                  {probeWinner.uri}
                </a>
              </p>
            ) : (
              <p class="ext-dbg-miss">✗ no match — this reference renders unresolved.</p>
            )}
            {probeAll.length > 0 ? (
              <>
                <p class="ext-dbg-sub">
                  Inventories carrying <code>{probeName}</code>:
                </p>
                <table class="ext-inv-table">
                  <thead>
                    <tr>
                      <th>Project</th>
                      <th>Domain</th>
                      <th>Role</th>
                      <th>Priority</th>
                      <th>URI</th>
                    </tr>
                  </thead>
                  <tbody>
                    {probeAll.map((o) => (
                      <tr>
                        <td>
                          <code>{o.project}</code>
                        </td>
                        <td>{o.domain}</td>
                        <td>{o.role}</td>
                        <td class="ext-inv-num">{o.priority}</td>
                        <td>
                          <a class="ext-inv-url" href={o.uri}>
                            {o.uri}
                          </a>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </>
            ) : (
              <p class="ext-dbg-sub">
                The name <code>{probeName}</code> is not in any registered inventory.
              </p>
            )}
          </div>
        )
      }

      <h3>Object search</h3>
      <form class="ext-dbg-form" method="get">
        <label>
          Name contains
          <input type="text" name="obj_q" value={objQ} placeholder="Mapping" />
        </label>
        <label>
          Project (optional)
          <input type="text" name="obj_project" value={objProject} placeholder="python" />
        </label>
        <input type="hidden" name="probe_module" value={probeModule} />
        <input type="hidden" name="probe_path" value={probePath} />
        <button class="ext-inv-btn" type="submit">Search</button>
      </form>
      {
        objQ &&
          (objResults.length === 0 ? (
            <p class="ext-inv-empty">No objects match.</p>
          ) : (
            <>
              <p class="ext-dbg-sub">
                {objResults.length}
                {objTruncated ? "+" : ""} object{objResults.length !== 1 ? "s" : ""}
                {objTruncated ? ` (showing first ${OBJ_LIMIT})` : ""}.
              </p>
              <table class="ext-inv-table">
                <thead>
                  <tr>
                    <th>Project</th>
                    <th>Name</th>
                    <th>Domain</th>
                    <th>Role</th>
                    <th>Priority</th>
                    <th>URI</th>
                  </tr>
                </thead>
                <tbody>
                  {objResults.map((o) => (
                    <tr>
                      <td>
                        <code>{o.project}</code>
                      </td>
                      <td>
                        <code>{o.name}</code>
                      </td>
                      <td>{o.domain}</td>
                      <td>{o.role}</td>
                      <td class="ext-inv-num">{o.priority}</td>
                      <td>
                        <a class="ext-inv-url" href={o.uri}>
                          {o.uri}
                        </a>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </>
          ))
      }
    </section>

    <ReingestPanel client:load entries={rawEntries} />
  </div>
</BaseLayout>

<style>
