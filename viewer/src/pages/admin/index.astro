  }

  :global(.reingest-bundle-list) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.reingest-bundle) {
    border: 1px solid var(--color-border, #ddd);
    border-radius: 6px;
    padding: 0.6rem 0.8rem;
    background: var(--color-surface, #fafafa);
  }

