    padding: 0.25rem 0.7rem;
    background: var(--color-surface, #f3f4f6);
    color: var(--color-error, #dc2626);
    border: 1px solid var(--color-error-border, #fca5a5);
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.8rem;
  }

