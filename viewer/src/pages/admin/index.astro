  :global(.ext-inv-table td) {
    text-align: left;
    padding: 0.3rem 0.6rem;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  :global(.ext-inv-table th) {
    color: var(--color-muted, #666);
    font-weight: 600;
    font-size: 0.78rem;
