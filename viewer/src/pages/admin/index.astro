    margin: 1.25rem 0 0.4rem;
    font-size: 0.95rem;
  }

  .ext-dbg-desc {
    margin: 0 0 0.5rem;
    color: var(--color-muted, #666);
    font-size: 0.9rem;
  }

  .ext-dbg-form {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .ext-dbg-form label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .ext-dbg-form input[type="text"] {
    padding: 0.35rem 0.5rem;
    border: 1px solid var(--color-border, #ccc);
    border-radius: 4px;
    background: var(--color-bg, #fff);
    color: inherit;
    font-size: 0.9rem;
