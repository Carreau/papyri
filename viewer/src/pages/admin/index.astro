  }

  .admin-stats-table tr.admin-stats-total td {
    border-bottom: none;
    border-top: 2px solid var(--color-border, #d1d5db);
  }

  :global(.clear-graphstore) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
