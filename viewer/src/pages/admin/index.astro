  :global(.ext-inv-drop:disabled) {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ---- ReingestPanel styles (scoped via :global since component is React) ---- */
  :global(.reingest-panel) {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  :global(.reingest-controls h2) {
    margin: 0 0 0.4rem;
  }

  :global(.reingest-desc) {
    margin: 0 0 1rem;
    color: var(--color-muted, #666);
    font-size: 0.9rem;
  }

  :global(.reingest-filters) {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 0.75rem;
  }

