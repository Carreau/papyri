    padding: 0.4rem 1rem;
    background: var(--color-accent, #2563eb);
    color: #fff;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    align-self: flex-end;
  }

  :global(.reingest-btn:disabled) {
    opacity: 0.5;
    cursor: not-allowed;
  }

  :global(.reingest-progress h3) {
