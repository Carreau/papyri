---
import { listBundles, listIngestedBundles } from "../lib/ir-reader.ts";
import { dataDir, ingestDb } from "../lib/paths.ts";
import "../styles/global.css";

const root = dataDir();
const bundles = await listBundles(root);
const ingested = await listIngestedBundles();

// Index bundles by (pkg, ver) so we can tell which ones are viewable.
const ingestedByKey = new Map<string, true>();
for (const b of ingested) ingestedByKey.set(`${b.pkg}/${b.version}`, true);

// Rows to display: union of gen bundles and ingested bundles. Viewable rows
// link through; gen-only rows are listed but marked as "not ingested".
interface Row {
  pkg: string;
  version: string;
  dirName: string | null;
  viewable: boolean;
}
const rows: Row[] = [];
for (const b of bundles) {
  const pkg = b.meta?.module ?? b.dirName;
  const version = b.meta?.version ?? "?";
  rows.push({
    pkg,
    version,
    dirName: b.dirName,
    viewable: ingestedByKey.has(`${pkg}/${version}`),
  });
}
for (const ib of ingested) {
  if (bundles.find((b) => b.meta?.module === ib.pkg && b.meta?.version === ib.version)) continue;
  rows.push({ pkg: ib.pkg, version: ib.version, dirName: null, viewable: true });
}
rows.sort((a, b) => `${a.pkg}/${a.version}`.localeCompare(`${b.pkg}/${b.version}`));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Papyri viewer</title>
  </head>
  <body>
    <main>
      <h1>Papyri viewer</h1>
      <p class="lede">
        Gen bundles: <code>{root}</code>. Graph DB: <code>{ingestDb()}</code>.
      </p>

      {
        rows.length === 0 ? (
          <div class="empty">
            No bundles found. Generate one with
            <code>papyri gen examples/papyri.toml --no-infer</code>, then
            ingest it with <code>papyri ingest ~/.papyri/data/&lt;bundle&gt;</code>.
          </div>
        ) : (
          <ul class="bundles">
            {rows.map((r) => (
              <li>
                {r.viewable ? (
                  <a class="name" href={`/${r.pkg}/${r.version}/`}>{r.pkg}</a>
                ) : (
                  <span class="name">{r.pkg}</span>
                )}
                <span class="version">{r.version}</span>
                <span class="dir">
                  {r.viewable ? (r.dirName ?? "ingested") : "gen only — run papyri ingest"}
                </span>
              </li>
            ))}
          </ul>
        )
      }
    </main>
  </body>
</html>
