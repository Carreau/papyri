---
import { listIngestedBundles } from "../lib/ir-reader.ts";
import BaseLayout from "../layouts/BaseLayout.astro";
import BundleCard from "../components/BundleCard.astro";
import BundleGridSearch from "../components/BundleGridSearch.tsx";

const ingested = await listIngestedBundles();

const bundlesForFilter = ingested.map((b) => ({
  pkg: b.pkg,
  summary: "",
}));
---

<BaseLayout title="Papyri viewer">
  <h1>Papyri viewer</h1>
  <p class="lede">
    {ingested.length} bundle{ingested.length !== 1 ? "s" : ""} ingested.
  </p>

  {
    ingested.length === 0 ? (
      <div class="empty">
        No ingested bundles found. Generate one with
        <code>papyri gen examples/papyri.toml --no-infer</code>, then ingest it
        with <code>papyri ingest ~/.papyri/data/&lt;bundle&gt;</code>.
      </div>
    ) : (
      <>
        <BundleGridSearch
          client:load
          bundles={bundlesForFilter}
          gridId="bundle-card-grid"
        />
        <div class="bundle-card-grid" id="bundle-card-grid">
          {ingested.map((b) => (
            <BundleCard pkg={b.pkg} version={b.version} />
          ))}
        </div>
      </>
    )
  }
</BaseLayout>
