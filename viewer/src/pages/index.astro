---
import { listIngestedBundles } from "../lib/ir-reader.ts";
import { ingestDb } from "../lib/paths.ts";
import Head from "../components/Head.astro";
import SiteHeader from "../components/SiteHeader.astro";
import "../styles/global.css";

const ingested = await listIngestedBundles();
---

<html lang="en">
  <head>
    <Head title="Papyri viewer" />
  </head>
  <body>
    <SiteHeader />
    <main>
      <h1>Papyri viewer</h1>
      <p class="lede">
        Graph DB: <code>{ingestDb()}</code>.
      </p>

      {
        ingested.length === 0 ? (
          <div class="empty">
            No ingested bundles found. Generate one with
            <code>papyri gen examples/papyri.toml --no-infer</code>, then
            ingest it with <code>papyri ingest ~/.papyri/data/&lt;bundle&gt;</code>.
          </div>
        ) : (
          <ul class="bundles">
            {ingested.map((b) => (
              <li>
                <a class="name" href={`/${b.pkg}/${b.version}/`}>{b.pkg}</a>
                <span class="version">{b.version}</span>
              </li>
            ))}
          </ul>
        )
      }
    </main>
  </body>
</html>
