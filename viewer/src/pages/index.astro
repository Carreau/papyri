---
import { listIngestedPackages } from "../lib/ir-reader.ts";
import { getBackends } from "../lib/backends.ts";
import BaseLayout from "../layouts/BaseLayout.astro";
import BundleCard from "../components/BundleCard.astro";
import BundleGridSearch from "../components/BundleGridSearch.tsx";
import { redirectToLoginIfNotAuthenticated } from "../lib/auth.ts";

export const prerender = false;

redirectToLoginIfNotAuthenticated(Astro);

const { blobStore } = await getBackends();
const packages = await listIngestedPackages(blobStore);

const bundlesForFilter = packages.map((p) => ({
  pkg: p.pkg,
  summary: "",
}));
---

<BaseLayout title="Papyri viewer">
  <h1>Papyri viewer</h1>
  <p class="lede">
    {packages.length} package{packages.length !== 1 ? "s" : ""} ingested.
  </p>

  {
    packages.length === 0 ? (
      <div class="empty">
        No ingested bundles found. Generate one with
        <code>papyri gen examples/papyri.toml --no-infer</code>, then upload it with{" "}
        <code>papyri upload ~/.papyri/data/&lt;bundle&gt;</code>.
      </div>
    ) : (
      <>
        <BundleGridSearch client:load bundles={bundlesForFilter} gridId="bundle-card-grid" />
        <div class="bundle-card-grid" id="bundle-card-grid">
          {packages.map((p) => (
            <BundleCard pkg={p.pkg} latest={p.latest} versionCount={p.versions.length} />
          ))}
        </div>
      </>
    )
  }
</BaseLayout>
