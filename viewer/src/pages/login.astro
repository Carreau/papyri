---
import BaseLayout from "../layouts/BaseLayout.astro";
import LoginForm from "../components/LoginForm.tsx";
import { isAuthenticated } from "../lib/auth.ts";
import { demoSeedActive, DEMO_USERNAME, DEMO_PASSWORD, getAuthDb } from "../lib/auth-db.ts";

export const prerender = false;

// Already signed in (valid, unexpired session) → no reason to show the form.
if (await isAuthenticated(Astro)) {
  return Astro.redirect("/");
}

// Surface the dev demo credentials only when the demo user was actually seeded.
// demoSeedActive() is necessary but not sufficient: seed() skips the demo user
// when any user already exists, so after a real admin is created the demo user
// is absent even in dev mode.
let demo = null;
if (demoSeedActive()) {
  const authDb = await getAuthDb();
  if (authDb.listUsers().some((u) => u.username === DEMO_USERNAME)) {
    demo = { username: DEMO_USERNAME, password: DEMO_PASSWORD };
  }
}
---

<BaseLayout title="Login - Papyri Viewer">
  <div class="login-page">
    <div class="login-card">
      <header class="login-card-header">
        <span class="login-card-mark" aria-hidden="true">&para;</span>
        <h1>Sign in to Papyri</h1>
        <p>Sign in to access admin tools, or <a href="/">browse docs as a guest</a>.</p>
      </header>
      <LoginForm client:load demo={demo} />
    </div>
  </div>
</BaseLayout>

<style>
  .login-page {
    min-height: calc(100vh - 120px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px 16px;
  }
  .login-card {
    width: 100%;
    max-width: 380px;
    background: var(--surface, #fff);
    border: 1px solid var(--border, #e5e5e5);
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    padding: 32px 28px;
  }
  .login-card-header {
    text-align: center;
    margin-bottom: 24px;
  }
  .login-card-mark {
    display: inline-block;
    font-size: 32px;
    line-height: 1;
    color: var(--accent, #0066cc);
    margin-bottom: 8px;
  }
  .login-card-header h1 {
    font-size: 20px;
    margin: 0 0 6px 0;
  }
  .login-card-header p {
    font-size: 13px;
    color: var(--muted, #666);
    margin: 0;
  }
</style>
