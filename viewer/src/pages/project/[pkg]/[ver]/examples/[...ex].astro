---
import {
  loadCbor,
  sectionChildren,
  resolveVersion,
  type SectionNode,
} from "../../../../../lib/ir-reader.ts";
import { getBackends } from "../../../../../lib/backends.ts";
import { buildXrefResolver } from "../../../../../lib/xref.ts";
import IrNode from "../../../../../components/IrNode.astro";
import BundleLayout from "../../../../../layouts/BundleLayout.astro";
import { linkForBundle } from "../../../../../lib/links.ts";

export const prerender = false;

const { pkg, ver, ex } = Astro.params;
if (!pkg || !ver || !ex) return new Response("Not found", { status: 404 });

const examplePath = ex;
const { blobStore, graphDb } = await getBackends();

const actualVer = await resolveVersion(graphDb, pkg, ver);
if (!actualVer) return new Response(`Package ${pkg} not found`, { status: 404 });

let section: SectionNode;
try {
  section = (await loadCbor(blobStore, pkg, actualVer, "examples", examplePath)) as SectionNode;
} catch {
  return new Response(`Example ${examplePath} not found`, { status: 404 });
}
const resolveXref = await buildXrefResolver(graphDb, section, pkg, actualVer);

const children = sectionChildren(section);
---

<BundleLayout
  pkg={pkg}
  ver={ver}
  actualVer={actualVer}
  title={`${examplePath} — ${pkg} ${ver}`}
  activeExamplePath={examplePath}
  rawKind="examples"
  rawPath={examplePath}
>
  <p class="crumb">
    <a href="/">bundles</a> / <a href={linkForBundle(pkg, ver)}>{pkg} {ver}</a> /
    <span>examples</span>
  </p>

  <header class="qa-header">
    <p class="kind">Example</p>
    <h1>{examplePath}</h1>
  </header>

  {
    children.length === 0 ? (
      <p class="lede">This example is empty.</p>
    ) : (
      <section class="doc-section">
        {children.map((c) => (
          <IrNode node={c} resolveXref={resolveXref} />
        ))}
      </section>
    )
  }
</BundleLayout>
