---
import { loadBundleNav } from "../../../../lib/nav.ts";
import { resolveVersion } from "../../../../lib/ir-reader.ts";
import { getBackends } from "../../../../lib/backends.ts";
import { linkForQualname } from "../../../../lib/links.ts";
import { countBrokenBackrefs } from "../../../../lib/graph.ts";
import BundleLayout from "../../../../layouts/BundleLayout.astro";

export const prerender = false;

const { pkg, ver } = Astro.params;
if (!pkg || !ver) return new Response(null, { status: 404 });

const { blobStore, graphDb } = await getBackends();
const actualVer = await resolveVersion(graphDb, pkg, ver);
if (!actualVer) return new Response(`Package ${pkg} not found`, { status: 404 });
const [nav, brokenBackrefCount] = await Promise.all([
  loadBundleNav(blobStore, pkg, actualVer, ver),
  countBrokenBackrefs(graphDb, pkg, actualVer),
]);

const hasDocs = nav.toc.length > 0 || nav.docs.length > 0;
const hasExamples = nav.examples.length > 0;
const docsHref = nav.docsIndexHref ?? nav.docs[0]?.href ?? null;
// Link to the root-package qualname page if it exists, otherwise the first qualname.
const apiHref = nav.qualnames.includes(pkg)
  ? linkForQualname(pkg, ver, pkg)
  : nav.qualnames.length > 0
    ? linkForQualname(pkg, ver, nav.qualnames[0]!)
    : null;
---

<BundleLayout pkg={pkg} ver={ver} actualVer={actualVer} title={`${pkg} ${ver} — Papyri viewer`}>
  <p class="crumb"><a href="/">&larr; bundles</a></p>
  <h1>
    {pkg}
    <span class="version">{ver}</span>
  </h1>
  {nav.meta.summary ? <p class="lede">{nav.meta.summary}</p> : null}
  <div class="bundle-index-nav">
    {
      hasDocs && docsHref ? (
        <a class="bundle-index-card" href={docsHref}>
          <span class="bundle-index-card-title">Narrative docs</span>
          <span class="bundle-index-card-count">
            {nav.docs.length + nav.tutorials.length} page
            {nav.docs.length + nav.tutorials.length !== 1 ? "s" : ""}
          </span>
        </a>
      ) : null
    }
    {
      apiHref ? (
        <a class="bundle-index-card" href={apiHref}>
          <span class="bundle-index-card-title">API reference</span>
          <span class="bundle-index-card-count">
            {nav.qualnames.length} item{nav.qualnames.length !== 1 ? "s" : ""}
          </span>
        </a>
      ) : null
    }
    {
      hasExamples ? (
        <a class="bundle-index-card" href={nav.examples[0]!.href}>
          <span class="bundle-index-card-title">Examples</span>
          <span class="bundle-index-card-count">
            {nav.examples.length} example{nav.examples.length !== 1 ? "s" : ""}
          </span>
        </a>
      ) : null
    }
  </div>

  <div class="diag-links">
    <a class="diag-link" href={`/project/${pkg}/${ver}/validate`}> Outgoing ref diagnostics </a>
    <a
      class:list={["diag-link", brokenBackrefCount > 0 && "diag-link-warn"]}
      href={`/project/${pkg}/${ver}/backref-validate`}
    >
      {
        brokenBackrefCount > 0
          ? `${brokenBackrefCount} broken incoming ref${brokenBackrefCount !== 1 ? "s" : ""}`
          : "Broken incoming refs"
      }
    </a>
  </div>
</BundleLayout>

<style>
  .diag-links {
    margin-top: 1.5rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .diag-link {
    font-size: 0.85rem;
    color: var(--fg-muted);
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.2rem 0.6rem;
  }
  .diag-link:hover {
    color: var(--accent);
    border-color: currentColor;
  }
  .diag-link-warn {
    color: var(--warn-fg, #b05800);
    border-color: currentColor;
  }
  .diag-link-warn:hover {
    color: var(--error-fg, #cc0000);
    border-color: currentColor;
  }
</style>
